# PHPStan - analyse statique
# Lancer avec : composer phpstan  ou  vendor/bin/phpstan analyse
# Documentation : https://phpstan.org/config-reference

parameters:
    level: 4
    treatPhpDocTypesAsCertain: false
    paths:
        - src
        - tests
    excludePaths:
        - tests/bootstrap.php
    ignoreErrors:
        - identifier: property.unusedType
    # Symfony : chemin vers le container (généré en dev)
    symfony:
        containerXmlPath: var/cache/dev/App_KernelDevDebugContainer.xml
    # Ignorer les erreurs connues / tiers si besoin
    # ignoreErrors:
    #     - '#Message#'
