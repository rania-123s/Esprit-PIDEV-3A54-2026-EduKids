{% extends 'base_frontoffice.html.twig' %}

{% block title %}Résultat - {{ quiz.titre }}{% endblock %}

{% block body %}
<div class="quiz-result-page min-vh-100 pb-5 bg-light">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                
                {# Score Card #}
                <div class="card border-0 shadow rounded-4 mb-4 overflow-hidden text-center position-relative bg-white play-zoom-in">
                    <div class="card-body p-5">
                        <h1 class="h4 fw-bold text-muted mb-4 text-uppercase tracking-wide">Résultat du Quiz</h1>
                        
                        <div class="mb-4 d-inline-block position-relative">
                            {% set pct = attempt.percentage %}
                            {% set color = pct >= 80 ? 'success' : (pct >= 50 ? 'warning' : 'danger') %}
                            
                            <div class="score-circle-container">
                                <svg viewBox="0 0 36 36" class="circular-chart {{ color }}">
                                    <path class="circle-bg"
                                        d="M18 2.0845
                                        a 15.9155 15.9155 0 0 1 0 31.831
                                        a 15.9155 15.9155 0 0 1 0 -31.831"
                                    />
                                    <path class="circle"
                                        stroke-dasharray="{{ pct }}, 100"
                                        d="M18 2.0845
                                        a 15.9155 15.9155 0 0 1 0 31.831
                                        a 15.9155 15.9155 0 0 1 0 -31.831"
                                    />
                                </svg>
                                <div class="score-text">
                                    <span class="display-4 fw-bold text-dark">{{ pct|number_format(0) }}%</span>
                                </div>
                            </div>
                        </div>

                        <h2 class="h3 fw-bold mb-2">{{ quiz.titre }}</h2>
                        <p class="fs-5 text-muted mb-4">
                            Vous avez obtenu <span class="fw-bold text-{{ color }}">{{ attempt.score }}</span> bonnes réponses sur {{ attempt.totalQuestions }}.
                        </p>
                        
                        <div class="d-flex justify-content-center gap-3 flex-wrap">
                            <a href="{{ path('quiz_front_play', { id: quiz.id }) }}" class="btn btn-primary rounded-pill px-4 py-2 shadow-sm">
                                <i class="bi bi-arrow-repeat me-2"></i> Rejouer
                            </a>
                            <a href="{{ path('quiz_front_list') }}" class="btn btn-outline-secondary rounded-pill px-4 py-2">
                                <i class="bi bi-grid me-2"></i> Autres quiz
                            </a>
                        </div>
                    </div>
                    <!-- Decorative background shapes -->
                    <div class="position-absolute top-0 start-0 p-3 opacity-10">
                        <i class="bi bi-patch-question-fill display-1 text-primary"></i>
                    </div>
                </div>

                {# Answers Review #}
                <div class="d-flex align-items-center mb-4 mt-5">
                    <h5 class="fw-bold mb-0 text-dark">
                        <i class="bi bi-check2-all me-2 text-primary"></i> Détail de vos réponses
                    </h5>
                    <div class="ms-auto">
                        <span class="badge bg-white text-dark border rounded-pill px-3 py-2 shadow-sm">
                            Date: {{ attempt.completedAt|date('d/m/Y H:i') }}
                        </span>
                    </div>
                </div>

                <div class="vstack gap-3">
                    {% for corr in corrections %}
                        <div class="card border-0 shadow-sm rounded-4 overflow-hidden answer-card {{ corr.correct ? 'border-start-success' : 'border-start-danger' }}">
                            <div class="card-body p-4">
                                <div class="d-flex gap-3">
                                    <div class="flex-shrink-0">
                                        {% if corr.correct %}
                                            <div class="rounded-circle bg-success bg-opacity-10 p-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                                <i class="bi bi-check-lg text-success fs-5"></i>
                                            </div>
                                        {% else %}
                                            <div class="rounded-circle bg-danger bg-opacity-10 p-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                                <i class="bi bi-x-lg text-danger fs-5"></i>
                                            </div>
                                        {% endif %}
                                    </div>
                                    <div class="flex-grow-1">
                                        <h6 class="fw-bold mb-3 text-dark">{{ corr.question.texte }}</h6>
                                        
                                        <div class="d-flex flex-column gap-2 small">
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="text-muted" style="min-width: 100px;">Votre réponse :</span>
                                                <span class="fw-semibold px-2 py-1 rounded-2 {{ corr.correct ? 'bg-success bg-opacity-10 text-success' : 'bg-danger bg-opacity-10 text-danger' }}">
                                                    {{ corr.userAnswer ?? 'Aucune réponse' }}
                                                </span>
                                            </div>
                                            
                                            {% if not corr.correct %}
                                                <div class="d-flex align-items-center gap-2">
                                                    <span class="text-muted" style="min-width: 100px;">Bonne réponse :</span>
                                                    <span class="fw-semibold text-success px-2 py-1 bg-success bg-opacity-10 rounded-2">
                                                        {% if corr.question.type == 'qcm' and corr.question.correctOption %}
                                                            {{ corr.question.correctOption.texte }}
                                                        {% elseif corr.question.bonneReponse is not null and corr.question.bonneReponse != '' %}
                                                            {{ corr.question.bonneReponse }}
                                                        {% else %}
                                                            Non définie
                                                        {% endif %}
                                                    </span>
                                                </div>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</div>

<style>
/* Circular Chart */
.score-circle-container {
    position: relative;
    width: 150px;
    height: 150px;
    margin: 0 auto;
}
.circular-chart {
    display: block;
    margin: 0 auto;
    max-width: 100%;
    max-height: 100%;
}
.circle-bg {
    fill: none;
    stroke: #eee;
    stroke-width: 2.5;
}
.circle {
    fill: none;
    stroke-width: 2.5;
    stroke-linecap: round;
    animation: progress 1.5s ease-out forwards;
}
.circular-chart.success .circle { stroke: #198754; }
.circular-chart.warning .circle { stroke: #ffc107; }
.circular-chart.danger .circle { stroke: #dc3545; }

@keyframes progress {
    0% { stroke-dasharray: 0 100; }
}

.score-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
}

/* Animations */
.play-zoom-in { animation: zoomIn 0.5s ease-out; }
@keyframes zoomIn { from { opacity: 0; transform: scale(0.9); } to { opacity: 1; transform: scale(1); } }

/* Cards */
.border-start-success { border-left: 5px solid #198754 !important; }
.border-start-danger { border-left: 5px solid #dc3545 !important; }
.tracking-wide { letter-spacing: 0.1em; }
</style>
{% endblock %}
