{% extends 'base_frontoffice.html.twig' %}

{% block title %}{{ quiz.titre }} - Quiz{% endblock %}

{% block body %}
<div class="quiz-show-page min-vh-100 pb-5 bg-light">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card border-0 shadow rounded-4 overflow-hidden fade-in-up bg-white position-relative">
                    {% if quiz.imageUrl %}
                        <div class="position-relative">
                            <img src="{{ quiz.imageUrl }}" class="card-img-top" alt="{{ quiz.titre }}" style="height: 300px; object-fit: cover;">
                            <div class="position-absolute top-0 start-0 w-100 h-100 bg-gradient-overlay"></div>
                        </div>
                    {% else %}
                        <div class="bg-primary bg-gradient d-flex align-items-center justify-content-center text-white" style="height: 220px;">
                            <i class="bi bi-patch-question-fill display-1 opacity-50"></i>
                        </div>
                    {% endif %}
                    
                    <div class="card-body p-4 p-lg-5">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                             <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2 fw-semibold">
                                <i class="bi bi-list-ol me-1"></i> {{ questions|length }} Question{{ questions|length > 1 ? 's' : '' }}
                            </span>
                            {% if quiz.chatbotEnabled %}
                                <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2 fw-semibold">
                                    <i class="bi bi-robot me-1"></i> Assistant IA
                                </span>
                            {% endif %}
                        </div>

                        <h1 class="display-6 fw-bold mb-3 text-dark">{{ quiz.titre }}</h1>
                        
                        {% if quiz.description %}
                            <div class="text-muted mb-4 fs-5 lh-base">{{ quiz.description|nl2br }}</div>
                        {% endif %}

                        <hr class="my-4 border-light">

                        <div class="d-flex flex-wrap gap-3 mt-4">
                            {% set play_url = isAdminPreview|default(false) ? previewPlayPath : path('quiz_front_play', { id: quiz.id }) %}
                            {% set back_url = isAdminPreview|default(false) ? backPath : path('quiz_front_list') %}
                            {% if app.user or isAdminPreview|default(false) %}
                                <a href="{{ play_url }}" class="btn btn-primary btn-lg rounded-pill px-5 shadow-sm hover-translate">
                                    <i class="bi bi-play-fill me-2 fs-4 align-middle"></i> Commencer
                                </a>
                                <a href="{{ back_url }}" class="btn btn-outline-secondary btn-lg rounded-pill px-4 hover-bg-light">
                                    {{ isAdminPreview|default(false) ? 'Retour à la liste' : 'Retour' }}
                                </a>
                            {% else %}
                                <div class="alert alert-warning border-0 rounded-4 w-100 d-flex align-items-center mb-0 p-4">
                                    <div class="flex-shrink-0 bg-warning bg-opacity-25 rounded-circle p-2 me-3">
                                        <i class="bi bi-lock-fill text-warning fs-4"></i>
                                    </div>
                                    <div>
                                        <p class="mb-2 fw-semibold">Connectez-vous pour jouer</p>
                                        <div class="d-flex gap-2">
                                            <a href="{{ path('app_login') }}" class="btn btn-sm btn-dark rounded-pill px-3">Se connecter</a>
                                            <a href="{{ back_url }}" class="btn btn-sm btn-outline-dark rounded-pill px-3">Retour</a>
                                        </div>
                                    </div>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-gradient-overlay { background: linear-gradient(to bottom, rgba(0,0,0,0) 0%, rgba(0,0,0,0.3) 100%); }
    .fade-in-up { animation: fadeInUp 0.5s ease-out forwards; }
    .hover-translate:hover { transform: translateY(-2px); }
    @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
</style>
{% endblock %}
