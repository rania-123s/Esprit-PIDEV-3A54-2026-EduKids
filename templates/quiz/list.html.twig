{% extends 'base_frontoffice.html.twig' %}

{% block title %}Quiz - EduKids{% endblock %}

{% block body %}
<section class="bg-blue align-items-center d-flex" style="background:url('{{ asset('assets/images/pattern/04.png') }}') no-repeat center center; background-size:cover;">
    <div class="container">
        <div class="row">
            <div class="col-12 text-center">
                <h1 class="text-white">Quiz Educatifs</h1>
                <div class="d-flex justify-content-center">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb breadcrumb-dark breadcrumb-dots mb-0">
                            <li class="breadcrumb-item"><a href="{{ path('home') }}">Home</a></li>
                            <li class="breadcrumb-item active" aria-current="page">Quiz</li>
                        </ol>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row mb-4 align-items-center g-3">
            <div class="col-xl-8">
                <form method="get" action="{{ path('quiz_front_list') }}" class="border rounded p-3">
                    <div class="row g-2 align-items-center">
                        <div class="col-lg-6">
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="bi bi-search"></i></span>
                                <input
                                    type="text"
                                    name="q"
                                    id="quiz-search-query"
                                    class="form-control border-start-0 ps-0"
                                    value="{{ searchQuery ?? '' }}"
                                    placeholder="Titre ou theme..."
                                    autocomplete="off"
                                >
                                <button type="button" id="quiz-voice-search-btn" class="btn btn-outline-secondary border-start-0" title="Recherche vocale" aria-label="Recherche vocale">
                                    <i class="bi bi-mic-fill"></i>
                                </button>
                            </div>
                        </div>
                        <div class="col-sm-3">
                            <select name="sort" class="form-select">
                                <option value="titre" {{ sort == 'titre' ? 'selected' : '' }}>Titre</option>
                                <option value="createdAt" {{ sort == 'createdAt' ? 'selected' : '' }}>Date</option>
                            </select>
                        </div>
                        <div class="col-sm-3">
                            <select name="order" class="form-select">
                                <option value="ASC" {{ order == 'ASC' ? 'selected' : '' }}>A-Z</option>
                                <option value="DESC" {{ order == 'DESC' ? 'selected' : '' }}>Z-A</option>
                            </select>
                        </div>
                    </div>
                    <div class="text-end mt-2">
                        <button type="submit" class="btn btn-primary btn-sm px-4">Appliquer</button>
                    </div>
                </form>
            </div>
            <div class="col-xl-4 d-flex justify-content-xl-end align-items-center">
                <p class="mb-0 text-end">{{ quizzes|length }} quiz disponible(s)</p>
            </div>
        </div>

        <div class="row g-4">
            {% for quiz in quizzes %}
                {% set quizImageUrl = quizImageUrls[quiz.id]|default(quiz.imageUrl) %}
                <div class="col-sm-6 col-xl-4">
                    <div class="card shadow h-100">
                        {% if quizImageUrl %}
                            <img src="{{ quizImageUrl }}" class="card-img-top" alt="{{ quiz.titre }}" style="height:220px; object-fit:cover;">
                        {% else %}
                            <div class="d-flex align-items-center justify-content-center bg-light text-muted" style="height:220px;">
                                <i class="bi bi-question-circle fs-1"></i>
                            </div>
                        {% endif %}

                        <div class="card-body pb-0">
                            <h5 class="card-title mb-2">
                                <a href="{{ path('quiz_front_show', { id: quiz.id }) }}">{{ quiz.titre }}</a>
                            </h5>
                            <p class="mb-2 text-truncate-2">
                                {{ quiz.description|striptags|slice(0, 105) }}{% if quiz.description|length > 105 %}...{% endif %}
                            </p>
                        </div>

                        <div class="card-footer pt-0 pb-3">
                            <hr>
                            <div class="d-flex gap-2">
                                <a href="{{ path('quiz_front_show', { id: quiz.id }) }}" class="btn btn-primary-soft w-100">Voir</a>
                                {% if app.user %}
                                    <a href="{{ path('quiz_front_play', { id: quiz.id }) }}" class="btn btn-primary w-100">Jouer</a>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12 text-center py-5">
                    <p class="mb-0">Aucun quiz trouve.</p>
                </div>
            {% endfor %}
        </div>
    </div>
</section>

<style>
#quiz-voice-search-btn.recording { background: #dc3545; color: #fff; border-color: #dc3545; }
#quiz-voice-search-btn.recording i { animation: quiz-pulse 1s ease-in-out infinite; }
@keyframes quiz-pulse { 50% { opacity: 0.6; } }
</style>

<script>
(function () {
    var input = document.getElementById('quiz-search-query');
    var btn = document.getElementById('quiz-voice-search-btn');
    if (!input || !btn) return;

    var SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
    if (!SpeechRecognition) {
        btn.title = 'Recherche vocale non supportee';
        btn.disabled = true;
        return;
    }

    var recognition = new SpeechRecognition();
    recognition.continuous = false;
    recognition.interimResults = false;
    recognition.lang = 'fr-FR';

    btn.addEventListener('click', function () {
        if (btn.classList.contains('recording')) {
            recognition.stop();
            return;
        }
        btn.classList.add('recording');
        recognition.start();
    });

    recognition.onresult = function (e) {
        var transcript = (e.results[e.resultIndex][0].transcript || '').trim();
        if (transcript) {
            input.value = transcript;
            input.form && input.form.submit();
        }
        btn.classList.remove('recording');
    };

    recognition.onend = function () { btn.classList.remove('recording'); };
    recognition.onerror = function () { btn.classList.remove('recording'); };
})();
</script>
{% endblock %}
