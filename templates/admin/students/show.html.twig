{% extends 'base_backoffice.html.twig' %}

{% block title %}{{ userType }} Details - Admin{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="{{ path('app_admin_page') }}">Dashboard</a></li>
                    <li class="breadcrumb-item"><a href="{{ path('admin_' ~ userType|lower ~ 's_index') }}">{{ userType }}s</a></li>
                    <li class="breadcrumb-item active">{{ user.firstName }} {{ user.lastName }}</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8 m-auto">
            <!-- User Profile Card -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white p-4">
                    <div class="d-flex align-items-center">
                        <div class="me-3">
                            {% if user.avatar %}
                                <img src="{{ asset('uploads/avatars/' ~ user.avatar) }}" 
                                     alt="Avatar" 
                                     class="rounded-circle" 
                                     style="width: 80px; height: 80px; object-fit: cover;">
                            {% else %}
                                <div class="rounded-circle bg-primary text-white fw-bold d-flex align-items-center justify-content-center" 
                                     style="width: 80px; height: 80px; font-size: 1.5rem;">
                                    {{ user.firstName|first|upper }}{{ user.lastName|first|upper }}
                                </div>
                            {% endif %}
                        </div>
                        <div>
                            <h4 class="mb-0 fw-bold">{{ user.firstName }} {{ user.lastName }}</h4>
                            <p class="text-muted mb-0">{{ user.email }}</p>
                        </div>
                        <div class="ms-auto">
                            {% if user.isActive %}
                                <span class="badge bg-success fs-6">
                                    <i class="bi bi-check-circle me-1"></i> Active
                                </span>
                            {% else %}
                                <span class="badge bg-secondary fs-6">
                                    <i class="bi bi-ban me-1"></i> Banned
                                </span>
                            {% endif %}
                        </div>
                    </div>
                </div>

                <div class="card-body p-4">
                    <!-- Personal Information -->
                    <div class="mb-4">
                        <h6 class="fw-bold text-uppercase text-muted small mb-3">
                            <i class="bi bi-person-fill me-2"></i> Personal Information
                        </h6>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="bg-light rounded p-3">
                                    <small class="text-muted d-block mb-1">First Name</small>
                                    <p class="mb-0 fw-semibold">{{ user.firstName ?? 'N/A' }}</p>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="bg-light rounded p-3">
                                    <small class="text-muted d-block mb-1">Last Name</small>
                                    <p class="mb-0 fw-semibold">{{ user.lastName ?? 'N/A' }}</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Contact Information -->
                    <div class="mb-4">
                        <h6 class="fw-bold text-uppercase text-muted small mb-3">
                            <i class="bi bi-envelope-fill me-2"></i> Contact Information
                        </h6>
                        <div class="bg-light rounded p-3">
                            <small class="text-muted d-block mb-1">Email Address</small>
                            <p class="mb-0 fw-semibold">{{ user.email }}</p>
                        </div>
                    </div>

                    <!-- Account Status -->
                    <div class="mb-4">
                        <h6 class="fw-bold text-uppercase text-muted small mb-3">
                            <i class="bi bi-shield-fill me-2"></i> Account Status
                        </h6>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="bg-light rounded p-3">
                                    <small class="text-muted d-block mb-1">Role</small>
                                    <span class="badge bg-dark">{{ userType }}</span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="bg-light rounded p-3">
                                    <small class="text-muted d-block mb-1">Verification Status</small>
                                    {% if user.isVerified %}
                                        <span class="badge bg-success">Verified</span>
                                    {% else %}
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-footer bg-light p-4">
                    <div class="d-flex justify-content-between flex-wrap gap-2">
                        <a href="{{ path('admin_' ~ userType|lower ~ 's_index') }}" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i> Back to List
                        </a>
                        <div class="d-flex gap-2">
                            <a href="{{ path('admin_' ~ userType|lower ~ 's_edit', {id: user.id}) }}" class="btn btn-primary">
                                <i class="bi bi-pencil-square me-1"></i> Edit
                            </a>
                            <a href="{{ path('admin_' ~ userType|lower ~ 's_block', {id: user.id}) }}" 
                               class="btn {% if user.isActive %}btn-dark{% else %}btn-success{% endif %}">
                                {% if user.isActive %}
                                    <i class="bi bi-ban me-1"></i> Ban
                                {% else %}
                                    <i class="bi bi-unlock me-1"></i> Unban
                                {% endif %}
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
