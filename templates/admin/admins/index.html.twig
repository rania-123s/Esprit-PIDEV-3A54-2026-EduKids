{% extends 'base_backoffice.html.twig' %}

{% block title %}{{ userType }}s Management - Admin{% endblock %}

{% block body %}
<div class="container-fluid">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="fw-bold mb-0">
                <i class="{{ userTypeIcon }} me-2"></i> {{ userType }}s Management
            </h1>
            <p class="text-muted">Manage all {{ userType|lower }} accounts</p>
        </div>
    </div>

    <!-- Search Bar & Filters -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <!-- Add New Button -->
                <a href="{{ path('admin_' ~ userType|lower ~ 's_new') }}" class="btn btn-success fw-bold">
                    <i class="bi bi-person-plus-fill me-1"></i> Add New {{ userType }}
                </a>

                <div class="d-flex gap-3 align-items-center">
                    <!-- Search -->
                    <form id="searchForm" method="GET" action="{{ path('admin_' ~ userType|lower ~ 's_index') }}" style="width: 350px;">
                        <input type="hidden" name="sort" value="{{ sortBy }}">
                        <input type="hidden" name="order" value="{{ sortOrder }}">
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0" style="border: 1.5px solid #0056b3;">
                                <i class="bi bi-search text-primary"></i>
                            </span>
                            <input type="text" 
                                   id="searchInput"
                                   class="form-control border-start-0" 
                                   name="q"
                                   placeholder="Search {{ userType|lower }}s..."
                                   value="{{ searchQuery }}"
                                   style="border: 1.5px solid #0056b3; border-left: none; font-size: 0.9rem;">
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Flash Messages -->
    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
            <i class="bi bi-check-circle me-2"></i>{{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
            <i class="bi bi-exclamation-circle me-2"></i>{{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    <!-- Users Table Card -->
    <div class="card border-0 shadow-sm">
        <div class="card-header {{ userTypeBadgeClass }} text-white p-4">
            <h5 class="mb-0 fw-bold">
                <i class="bi bi-table me-2"></i> All {{ userType }}s
            </h5>
        </div>

        <div class="card-body p-0">
            {% if users|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="fw-bold ps-4 py-3">
                                    <a href="{{ path('admin_' ~ userType|lower ~ 's_index', {q: searchQuery, sort: 'firstName', order: (sortBy == 'firstName' and sortOrder == 'ASC') ? 'DESC' : 'ASC'}) }}" 
                                       class="text-decoration-none text-dark d-flex align-items-center">
                                        Name
                                        {% if sortBy == 'firstName' %}
                                            <i class="bi bi-chevron-{{ sortOrder == 'ASC' ? 'up' : 'down' }} ms-1"></i>
                                        {% endif %}
                                    </a>
                                </th>
                                <th class="fw-bold py-3">
                                    <a href="{{ path('admin_' ~ userType|lower ~ 's_index', {q: searchQuery, sort: 'email', order: (sortBy == 'email' and sortOrder == 'ASC') ? 'DESC' : 'ASC'}) }}" 
                                       class="text-decoration-none text-dark d-flex align-items-center">
                                        Email
                                        {% if sortBy == 'email' %}
                                            <i class="bi bi-chevron-{{ sortOrder == 'ASC' ? 'up' : 'down' }} ms-1"></i>
                                        {% endif %}
                                    </a>
                                </th>
                                <th class="fw-bold py-3">
                                    <a href="{{ path('admin_' ~ userType|lower ~ 's_index', {q: searchQuery, sort: 'isActive', order: (sortBy == 'isActive' and sortOrder == 'ASC') ? 'DESC' : 'ASC'}) }}" 
                                       class="text-decoration-none text-dark d-flex align-items-center">
                                        Status
                                        {% if sortBy == 'isActive' %}
                                            <i class="bi bi-chevron-{{ sortOrder == 'ASC' ? 'up' : 'down' }} ms-1"></i>
                                        {% endif %}
                                    </a>
                                </th>
                                <th class="fw-bold text-center py-3">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for user in users %}
                                <tr class="align-middle border-bottom">
                                    <td class="ps-4 py-3">
                                        <div class="d-flex align-items-center">
                                            {% if user.avatar %}
                                                <img src="{{ asset('uploads/avatars/' ~ user.avatar) }}" 
                                                     alt="avatar" 
                                                     class="rounded-circle me-3" 
                                                     style="width: 40px; height: 40px; object-fit: cover;">
                                            {% else %}
                                                <div class="rounded-circle {{ userTypeBadgeClass }} text-white fw-bold d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px; font-size: 0.9rem;">
                                                    {{ user.firstName|first|upper }}{{ user.lastName|first|upper }}
                                                </div>
                                            {% endif %}
                                            <div>
                                                <p class="mb-0 fw-bold">{{ user.firstName }} {{ user.lastName }}</p>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-3">
                                        <code style="background-color: #f5f5f5; padding: 0.25rem 0.5rem; border-radius: 0.25rem; color: #333;">{{ user.email }}</code>
                                    </td>
                                    <td class="py-3">
                                        {% if user.isActive %}
                                            <span class="badge bg-success">
                                                <i class="bi bi-check-circle me-1"></i> Active
                                            </span>
                                        {% else %}
                                            <span class="badge bg-secondary">
                                                <i class="bi bi-ban me-1"></i> Banned
                                            </span>
                                        {% endif %}
                                    </td>
                                    <td class="text-center py-3">
                                        <div class="d-flex justify-content-center gap-2">
                                            <a href="{{ path('admin_' ~ userType|lower ~ 's_show', {id: user.id}) }}" 
                                               class="btn btn-sm btn-outline-info fw-bold">
                                                <i class="bi bi-eye"></i> View
                                            </a>
                                            <a href="{{ path('admin_' ~ userType|lower ~ 's_edit', {id: user.id}) }}" 
                                               class="btn btn-sm btn-outline-primary fw-bold">
                                                <i class="bi bi-pencil-square"></i> Edit
                                            </a>
                                            <a href="{{ path('admin_' ~ userType|lower ~ 's_block', {id: user.id}) }}" 
                                               class="btn btn-sm {% if user.isActive %}btn-outline-dark{% else %}btn-outline-success{% endif %} fw-bold">
                                                {% if user.isActive %}
                                                    <i class="bi bi-ban"></i> Ban
                                                {% else %}
                                                    <i class="bi bi-unlock"></i> Unban
                                                {% endif %}
                                            </a>
                                            <form method="post" action="{{ path('admin_' ~ userType|lower ~ 's_delete', {id: user.id}) }}" 
                                                  onsubmit="return confirm('Are you sure you want to delete this {{ userType|lower }}?');"
                                                  class="d-inline">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                                                <button type="submit" class="btn btn-sm btn-outline-danger fw-bold">
                                                    <i class="bi bi-trash"></i> Delete
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="text-center py-5">
                    <i class="{{ userTypeIcon }} display-4 text-muted"></i>
                    <h5 class="mt-3 text-muted">No {{ userType|lower }}s found</h5>
                    <p class="text-muted">Get started by adding a new {{ userType|lower }}.</p>
                    <a href="{{ path('admin_' ~ userType|lower ~ 's_new') }}" class="btn btn-primary">
                        <i class="bi bi-person-plus-fill me-1"></i> Add {{ userType }}
                    </a>
                </div>
            {% endif %}
        </div>

        {% if users|length > 0 %}
        <div class="card-footer bg-light border-top p-3">
            <p class="mb-0 text-muted">
                Showing <strong>{{ users|length }}</strong> {{ userType|lower }}{{ users|length > 1 ? 's' : '' }}
            </p>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}
