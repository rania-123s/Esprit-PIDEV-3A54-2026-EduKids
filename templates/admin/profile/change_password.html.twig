{% extends 'base_backoffice.html.twig' %}

{% block title %}Change Password - Admin{% endblock %}

{% block body %}
<div class="container-fluid">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="fw-bold mb-0">
                <i class="bi bi-lock-fill me-2"></i> Change Password
            </h1>
            <p class="text-muted">Update your account password</p>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-primary text-white p-4">
                    <h5 class="mb-0 fw-bold">
                        <i class="bi bi-shield-lock me-2"></i> Update Password
                    </h5>
                </div>

                <div class="card-body p-4">
                    {% for message in app.flashes('success') %}
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle me-2"></i>{{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endfor %}
                    {% for message in app.flashes('error') %}
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-circle me-2"></i>{{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endfor %}

                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                        <div class="mb-3">
                            {{ form_label(form.currentPassword, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {{ form_widget(form.currentPassword) }}
                            {{ form_errors(form.currentPassword) }}
                        </div>

                        <hr class="my-4">

                        <div class="mb-3">
                            {{ form_label(form.newPassword.first, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {{ form_widget(form.newPassword.first) }}
                            {{ form_errors(form.newPassword.first) }}
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.newPassword.second, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {{ form_widget(form.newPassword.second) }}
                            {{ form_errors(form.newPassword.second) }}
                        </div>

                        {{ form_errors(form.newPassword) }}

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary fw-bold">
                                <i class="bi bi-check-lg me-1"></i> Update Password
                            </button>
                            <a href="{{ path('user_profile_settings') }}" class="btn btn-outline-secondary fw-bold">Cancel</a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-light border-bottom p-4">
                    <h5 class="mb-0 fw-bold">
                        <i class="bi bi-info-circle me-2"></i> Password Tips
                    </h5>
                </div>
                <div class="card-body p-4">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i> Use at least 8 characters</li>
                        <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i> Include uppercase and lowercase letters</li>
                        <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i> Include at least one number</li>
                        <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i> Include a special character (!@#$%)</li>
                        <li><i class="bi bi-x-circle text-danger me-2"></i> Don't reuse passwords from other sites</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
