{% extends 'base_backoffice.html.twig' %}

{% block title %}Admin Dashboard - EduKids{% endblock %}

{% block body %}
<div class="container-fluid">
    <!-- Welcome Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="bg-primary bg-opacity-10 rounded-3 p-4">
                <div class="d-flex align-items-center">
                    <div>
                        <h1 class="fw-bold mb-1">
                            <i class="bi bi-speedometer2 me-2"></i>Welcome back, {{ app.user.firstName }}!
                        </h1>
                        <p class="text-muted mb-0">Here's what's happening with EduKids today.</p>
                    </div>
                    <div class="ms-auto d-none d-md-block">
                        <i class="bi bi-graph-up-arrow display-4 text-primary"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="row g-4 mb-4">
        <!-- Total Users -->
        <div class="col-sm-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="bg-primary bg-opacity-10 rounded-circle p-3">
                                <i class="bi bi-people-fill text-primary fs-4"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h3 class="fw-bold mb-0">{{ totalUsers }}</h3>
                            <p class="text-muted small mb-0">Total Users</p>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0 pt-0">
                    <a href="{{ path('admin_user_index') }}" class="btn btn-sm btn-outline-primary w-100">
                        View All <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Students -->
        <div class="col-sm-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="bg-info bg-opacity-10 rounded-circle p-3">
                                <i class="bi bi-mortarboard-fill text-info fs-4"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h3 class="fw-bold mb-0">{{ totalStudents }}</h3>
                            <p class="text-muted small mb-0">Students</p>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0 pt-0">
                    <a href="{{ path('admin_students_index') }}" class="btn btn-sm btn-outline-info w-100">
                        Manage <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Parents -->
        <div class="col-sm-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="bg-success bg-opacity-10 rounded-circle p-3">
                                <i class="bi bi-people text-success fs-4"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h3 class="fw-bold mb-0">{{ totalParents }}</h3>
                            <p class="text-muted small mb-0">Parents</p>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0 pt-0">
                    <a href="{{ path('admin_parents_index') }}" class="btn btn-sm btn-outline-success w-100">
                        Manage <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Admins -->
        <div class="col-sm-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="bg-danger bg-opacity-10 rounded-circle p-3">
                                <i class="bi bi-shield-fill text-danger fs-4"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h3 class="fw-bold mb-0">{{ totalAdmins }}</h3>
                            <p class="text-muted small mb-0">Administrators</p>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0 pt-0">
                    <a href="{{ path('admin_admins_index') }}" class="btn btn-sm btn-outline-danger w-100">
                        Manage <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Second Row Stats -->
    <div class="row g-4 mb-4">
        <!-- Active Users -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <h5 class="text-muted small mb-1">Active Users</h5>
                            <h2 class="fw-bold mb-0">{{ activeUsers }}</h2>
                        </div>
                        <div class="bg-success bg-opacity-10 rounded p-3">
                            <i class="bi bi-check-circle-fill text-success fs-3"></i>
                        </div>
                    </div>
                    <div class="mt-3">
                        <div class="progress" style="height: 8px;">
                            <div class="progress-bar bg-success" role="progressbar" 
                                 style="width: {{ totalUsers > 0 ? (activeUsers / totalUsers * 100)|round : 0 }}%"></div>
                        </div>
                        <small class="text-muted">{{ totalUsers > 0 ? ((activeUsers / totalUsers * 100)|round) : 0 }}% of total users</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Courses -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <h5 class="text-muted small mb-1">Total Courses</h5>
                            <h2 class="fw-bold mb-0">{{ totalCourses }}</h2>
                        </div>
                        <div class="bg-warning bg-opacity-10 rounded p-3">
                            <i class="bi bi-book-fill text-warning fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h5 class="text-muted small mb-3">Quick Actions</h5>
                    <div class="d-grid gap-2">
                        <a href="{{ path('admin_students_new') }}" class="btn btn-outline-info btn-sm">
                            <i class="bi bi-person-plus me-1"></i> Add Student
                        </a>
                        <a href="{{ path('admin_parents_new') }}" class="btn btn-outline-success btn-sm">
                            <i class="bi bi-person-plus me-1"></i> Add Parent
                        </a>
                        <a href="{{ path('admin_admins_new') }}" class="btn btn-outline-danger btn-sm">
                            <i class="bi bi-person-plus me-1"></i> Add Admin
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Users Table -->
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-bold">
                            <i class="bi bi-clock-history me-2"></i>Recent Users
                        </h5>
                        <a href="{{ path('admin_user_index') }}" class="btn btn-sm btn-primary">
                            View All <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
                <div class="card-body p-0">
                    {% if recentUsers|length > 0 %}
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4 py-3">User</th>
                                    <th class="py-3">Email</th>
                                    <th class="py-3">Role</th>
                                    <th class="py-3">Status</th>
                                    <th class="py-3 text-center">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for user in recentUsers %}
                                <tr>
                                    <td class="ps-4 py-3">
                                        <div class="d-flex align-items-center">
                                            {% if user.avatar %}
                                                <img src="{{ asset('uploads/avatars/' ~ user.avatar) }}" 
                                                     alt="avatar" 
                                                     class="rounded-circle me-2" 
                                                     style="width: 35px; height: 35px; object-fit: cover;">
                                            {% else %}
                                                <div class="rounded-circle bg-primary text-white fw-bold d-flex align-items-center justify-content-center me-2" 
                                                     style="width: 35px; height: 35px; font-size: 0.8rem;">
                                                    {{ user.firstName|first|upper }}{{ user.lastName|first|upper }}
                                                </div>
                                            {% endif %}
                                            <span class="fw-semibold">{{ user.firstName }} {{ user.lastName }}</span>
                                        </div>
                                    </td>
                                    <td class="py-3">
                                        <code class="bg-light px-2 py-1 rounded">{{ user.email }}</code>
                                    </td>
                                    <td class="py-3">
                                        {% for role in user.roles %}
                                            {% if role != 'ROLE_USER' %}
                                                <span class="badge {% if role == 'ROLE_ADMIN' %}bg-danger{% elseif role == 'ROLE_ELEVE' %}bg-info{% else %}bg-success{% endif %}">
                                                    {{ role|replace({'ROLE_': ''}) }}
                                                </span>
                                            {% endif %}
                                        {% endfor %}
                                    </td>
                                    <td class="py-3">
                                        {% if user.isActive %}
                                            <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Active</span>
                                        {% else %}
                                            <span class="badge bg-secondary"><i class="bi bi-ban me-1"></i>Banned</span>
                                        {% endif %}
                                    </td>
                                    <td class="py-3 text-center">
                                        <a href="{{ path('admin_user_show', {id: user.id}) }}" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% else %}
                    <div class="text-center py-5">
                        <i class="bi bi-people display-4 text-muted"></i>
                        <p class="text-muted mt-2">No users yet</p>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
