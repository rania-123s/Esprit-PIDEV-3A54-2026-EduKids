{% set currentRouteParams = app.request.attributes.get('_route_params')|default({}) %}
{% set currentQueryParams = app.request.query.all|default({}) %}
{% set baseParams = currentRouteParams|merge(currentQueryParams) %}
{% if currentRoute %}
	{% set enUrl = path(currentRoute, baseParams|merge({'_locale': 'en'})) %}
	{% set frUrl = path(currentRoute, baseParams|merge({'_locale': 'fr'})) %}
	{% set arUrl = path(currentRoute, baseParams|merge({'_locale': 'ar'})) %}
{% else %}
	{% set enUrl = path('app_home_page') ~ '?_locale=en' %}
	{% set frUrl = path('app_home_page') ~ '?_locale=fr' %}
	{% set arUrl = path('app_home_page') ~ '?_locale=ar' %}
{% endif %}

