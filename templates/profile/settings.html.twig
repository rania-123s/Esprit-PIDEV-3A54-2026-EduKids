{% extends 'base_frontoffice.html.twig' %}

{% block title %}Account Settings{% endblock %}

{% block body %}
<div class="container-fluid">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="fw-bold mb-0">
                <i class="bi bi-gear-fill me-2"></i> Account Settings
            </h1>
            <p class="text-muted">Manage your account preferences and security</p>
        </div>
    </div>

    <!-- Settings Cards -->
    <div class="row">
        <!-- Profile Settings -->
        <div class="col-md-6 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-primary text-white p-4">
                    <h5 class="mb-0 fw-bold">
                        <i class="bi bi-person-circle me-2"></i> Profile Settings
                    </h5>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted small mb-3">Update your personal information and profile details.</p>
                    <a href="{{ path('user_profile_edit') }}" class="btn btn-primary btn-sm">
                        <i class="bi bi-pencil-square me-1"></i> Edit Profile
                    </a>
                </div>
            </div>
        </div>

        <!-- Security Settings -->
        <div class="col-md-6 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-info text-white p-4">
                    <h5 class="mb-0 fw-bold">
                        <i class="bi bi-shield-lock me-2"></i> Security Settings
                    </h5>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted small mb-3">Manage your password and security options.</p>
                    <a href="{{ path('user_change_password') }}" class="btn btn-info btn-sm">
                        <i class="bi bi-lock-fill me-1"></i> Change Password
                    </a>
                </div>
            </div>
        </div>

        <!-- Notification Settings -->
        <div class="col-md-6 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-warning text-white p-4">
                    <h5 class="mb-0 fw-bold">
                        <i class="bi bi-bell me-2"></i> Notification Settings
                    </h5>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted small mb-3">Control how you receive notifications.</p>
                    <button class="btn btn-warning btn-sm" disabled title="Coming soon">
                        <i class="bi bi-bell-fill me-1"></i> Manage Notifications
                    </button>
                </div>
            </div>
        </div>

        <!-- Delete Account -->
        <div class="col-md-6 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-danger text-white p-4">
                    <h5 class="mb-0 fw-bold">
                        <i class="bi bi-exclamation-triangle me-2"></i> Danger Zone
                    </h5>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted small mb-3">Permanently delete your account and all associated data. This action cannot be undone.</p>
                    <form method="post" action="{{ path('user_delete_account') }}" 
                          onsubmit="return confirm('Are you absolutely sure? This will permanently delete your account and all your data. This action cannot be undone.');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete-account') }}">
                        <button type="submit" class="btn btn-outline-danger btn-sm">
                            <i class="bi bi-trash me-1"></i> Delete My Account
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Activity Section -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-light border-bottom p-4">
                    <h5 class="mb-0 fw-bold">
                        <i class="bi bi-clock-history me-2"></i> Account Activity
                    </h5>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted small">
                        Your account security is important to us. We monitor all login activities and suspicious behavior.
                    </p>
                    <div class="alert alert-info" role="alert">
                        <i class="bi bi-info-circle me-2"></i>
                        <strong>Last Login:</strong> Just now
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
