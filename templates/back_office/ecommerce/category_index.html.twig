{% extends 'back_office/ecommerce_base.html.twig' %}

{% block title %}Gestion des Catégories - Admin{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-bold mb-0 ecommerce-admin-header"><i class="bi bi-tags me-2 text-primary"></i>Gestion des Catégories</h1>
            <p class="small mb-0" style="color: #4b5563 !important;">Organisez vos produits par catégorie.</p>
        </div>
        <a href="{{ path('ecommerce_admin_category_new') }}" class="btn btn-primary shadow-sm rounded-pill px-4">
            <i class="bi bi-plus-circle me-2"></i> Nouvelle Catégorie
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 border-start border-success border-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    <div class="card ecommerce-admin-card border-0 shadow-sm mb-4">
        <div class="card-body bg-light rounded-3 p-3">
             <form method="get" action="{{ path('ecommerce_admin_category_index') }}" class="row g-3 align-items-end">
                <div class="col-md-6">
                    <label class="form-label fw-semibold small text-uppercase" style="color: #374151 !important;">Recherche</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="q" class="form-control border-start-0" value="{{ searchQuery ?? '' }}" placeholder="Nom, description...">
                    </div>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary w-100 fw-semibold rounded-pill"><i class="bi bi-funnel me-1"></i> Filtrer</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card ecommerce-admin-card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-uppercase small" style="color: #1f2937 !important;">
                    <tr>
                        <th class="ps-4 py-3 border-0 rounded-start">Nom</th>
                        <th class="py-3 border-0">Description</th>
                        <th class="pe-4 py-3 border-0 rounded-end text-end">Actions</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    {% for category in categories %}
                        <tr>
                            <td class="ps-4 py-3 fw-bold text-dark">
                                {{ category.nom }}
                            </td>
                            <td class="py-3" style="color: #4b5563 !important;">
                                {{ category.description|slice(0, 100) }}{% if category.description|length > 100 %}...{% endif %}
                            </td>
                            <td class="pe-4 py-3 text-end">
                                <div class="btn-group">
                                    <a href="{{ path('ecommerce_admin_category_edit', { id: category.id }) }}" class="btn btn-sm btn-outline-secondary" title="Modifier">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form method="post" action="{{ path('ecommerce_admin_category_delete', { id: category.id }) }}" class="d-inline" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette catégorie ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_category' ~ category.id) }}">
                                        <button type="submit" class="btn btn-sm btn-outline-danger border-start-0" title="Supprimer">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="3" class="text-center py-5" style="color: #4b5563 !important;">
                                <i class="bi bi-tags fs-1 d-block mb-3" style="opacity: .4;"></i>
                                Aucun résultat trouvé.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
         <div class="card-footer bg-white py-3 border-0">
             <small style="color: #4b5563 !important;">{{ categories|length }} catégorie(s) affichée(s)</small>
        </div>
    </div>
</div>
{% endblock %}
