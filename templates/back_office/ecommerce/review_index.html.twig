{% extends 'back_office/ecommerce_base.html.twig' %}

{% block title %}Avis clients - Admin E-commerce{% endblock %}

{% block body %}
<style>
    .ecom-review-tuned .card {
        border-radius: 14px;
        overflow: hidden;
        animation: panelIn 0.45s ease both;
    }

    .ecom-review-tuned .card-header {
        padding-top: 1rem;
        padding-bottom: 1rem;
    }

    .ecom-review-tuned .form-control,
    .ecom-review-tuned .form-select {
        border-radius: 10px;
    }

    .ecom-review-tuned .table thead th {
        font-weight: 700;
        letter-spacing: 0.2px;
    }

    .ecom-review-tuned .table tbody tr {
        transition: background-color 0.2s ease;
        animation: rowIn 0.35s ease both;
    }

    .ecom-review-tuned .table tbody tr:hover {
        background-color: rgba(13, 110, 253, 0.04);
    }

    .ecom-review-tuned .results-meta {
        font-size: 0.85rem;
        color: #6c757d;
        animation: fadeInSoft 0.45s ease both;
    }

    .ecom-review-tuned .row.mb-3 {
        animation: slideDownIn 0.45s ease both;
    }

    .ecom-review-tuned .row.g-4.mb-4 > div {
        animation: riseIn 0.45s ease both;
    }

    .ecom-review-tuned .row.g-4.mb-4 > div:nth-child(2) {
        animation-delay: 0.08s;
    }

    .ecom-review-tuned .row.g-4.mb-4 > div:nth-child(3) {
        animation-delay: 0.16s;
    }

    .ecom-review-tuned .btn-outline-secondary {
        animation: pulseSoft 1.7s ease-in-out infinite;
    }

    .ecom-review-tuned .table tbody tr:nth-child(1) { animation-delay: 0.02s; }
    .ecom-review-tuned .table tbody tr:nth-child(2) { animation-delay: 0.05s; }
    .ecom-review-tuned .table tbody tr:nth-child(3) { animation-delay: 0.08s; }
    .ecom-review-tuned .table tbody tr:nth-child(4) { animation-delay: 0.11s; }
    .ecom-review-tuned .table tbody tr:nth-child(5) { animation-delay: 0.14s; }

    @keyframes slideDownIn {
        from { opacity: 0; transform: translateY(-8px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @keyframes riseIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @keyframes panelIn {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @keyframes fadeInSoft {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    @keyframes rowIn {
        from { opacity: 0; transform: translateX(8px); }
        to { opacity: 1; transform: translateX(0); }
    }

    @keyframes pulseSoft {
        0%, 100% { box-shadow: 0 0 0 0 rgba(108, 117, 125, 0.12); }
        50% { box-shadow: 0 0 0 6px rgba(108, 117, 125, 0.04); }
    }

    @media (max-width: 768px) {
        .ecom-review-tuned .card-header .row > div {
            width: 100%;
        }
    }
</style>

{% set totalReviews = reviews|length %}
{% set pendingCount = 0 %}
{% set approvedCount = 0 %}
{% set rejectedCount = 0 %}
{% for review in reviews %}
    {% if review.status == 'pending' %}
        {% set pendingCount = pendingCount + 1 %}
    {% elseif review.status == 'approved' %}
        {% set approvedCount = approvedCount + 1 %}
    {% elseif review.status == 'rejected' %}
        {% set rejectedCount = rejectedCount + 1 %}
    {% endif %}
{% endfor %}

<div class="ecom-review-tuned">
    <div class="row mb-3">
        <div class="col-12 d-sm-flex justify-content-between align-items-center">
            <h1 class="h3 mb-2 mb-sm-0 ecommerce-admin-header">Avis clients</h1>
            <div class="d-flex gap-2">
                <a href="{{ path('ecommerce_admin_review_index', { status: 'pending' }) }}" class="btn btn-sm {{ currentStatus == 'pending' ? 'btn-primary' : 'btn-outline-primary' }}">En attente</a>
                <a href="{{ path('ecommerce_admin_review_index', { status: 'all' }) }}" class="btn btn-sm {{ currentStatus == 'all' ? 'btn-primary' : 'btn-outline-primary' }}">Tous</a>
            </div>
        </div>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 border-start border-success border-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    <div class="row g-4 mb-4">
        <div class="col-sm-6 col-lg-4">
            <div class="text-center p-4 bg-primary bg-opacity-10 border border-primary rounded-3">
                <h6>Total Avis</h6>
                <h2 class="mb-0 fs-1 text-primary">{{ totalReviews }}</h2>
            </div>
        </div>
        <div class="col-sm-6 col-lg-4">
            <div class="text-center p-4 bg-warning bg-opacity-10 border border-warning rounded-3">
                <h6>En attente</h6>
                <h2 class="mb-0 fs-1 text-warning">{{ pendingCount }}</h2>
            </div>
        </div>
        <div class="col-sm-6 col-lg-4">
            <div class="text-center p-4 bg-success bg-opacity-10 border border-success rounded-3">
                <h6>Approuves</h6>
                <h2 class="mb-0 fs-1 text-success">{{ approvedCount }}</h2>
            </div>
        </div>
    </div>

    <div class="card bg-transparent border">
        <div class="card-header bg-light border-bottom">
            <div class="row g-3 align-items-center justify-content-between">
                <div class="col-md-8">
                    <div class="results-meta">
                        {{ totalReviews }} resultat(s)
                        {% if currentStatus == 'pending' %}
                            | filtre: En attente
                        {% else %}
                            | filtre: Tous
                        {% endif %}
                    </div>
                </div>
                <div class="col-md-4 text-md-end">
                    <a href="{{ path('ecommerce_admin_review_index', { status: currentStatus == 'pending' ? 'all' : 'pending' }) }}" class="btn btn-sm btn-outline-secondary">
                        Basculer vue
                    </a>
                </div>
            </div>
        </div>

        <div class="card-body">
            <div class="table-responsive border-0 rounded-3">
                <table class="table table-dark-gray align-middle p-4 mb-0 table-hover">
                    <thead>
                        <tr>
                            <th scope="col" class="border-0 rounded-start">Produit</th>
                            <th scope="col" class="border-0">Client</th>
                            <th scope="col" class="border-0">Note</th>
                            <th scope="col" class="border-0">Commentaire</th>
                            <th scope="col" class="border-0">Date</th>
                            <th scope="col" class="border-0">Statut</th>
                            <th scope="col" class="border-0 rounded-end text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for review in reviews %}
                            <tr>
                                <td>
                                    <a href="{{ path('ecommerce_produit_show', { id: review.produit.id }) }}" class="fw-semibold text-decoration-none" style="color: #1f2937 !important;">{{ review.produit.nom }}</a>
                                </td>
                                <td>{{ review.user.email }}</td>
                                <td>
                                    <span class="text-warning">
                                        {% for i in 1..5 %}
                                            <i class="bi bi-star{{ i <= review.rating ? '-fill' : '' }}"></i>
                                        {% endfor %}
                                    </span>
                                </td>
                                <td class="small">{{ review.comment|slice(0, 80) }}{% if review.comment|length > 80 %}...{% endif %}</td>
                                <td class="small">{{ review.createdAt|date('d/m/Y H:i') }}</td>
                                <td>
                                    {% if review.status == 'pending' %}
                                        <span class="badge bg-warning text-dark">En attente</span>
                                    {% elseif review.status == 'approved' %}
                                        <span class="badge bg-success">Approuve</span>
                                    {% else %}
                                        <span class="badge bg-danger">Rejete</span>
                                    {% endif %}
                                </td>
                                <td class="text-end">
                                    {% if review.status == 'pending' %}
                                        <form method="post" action="{{ path('ecommerce_admin_review_approve', { id: review.id }) }}" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('review_approve' ~ review.id) }}">
                                            <button type="submit" class="btn btn-sm btn-success-soft me-1 mb-1 mb-md-0">Approuver</button>
                                        </form>
                                        <form method="post" action="{{ path('ecommerce_admin_review_reject', { id: review.id }) }}" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('review_reject' ~ review.id) }}">
                                            <button type="submit" class="btn btn-sm btn-danger-soft mb-1 mb-md-0">Rejeter</button>
                                        </form>
                                    {% else %}
                                        <span class="text-muted small">-</span>
                                    {% endif %}
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="7">Aucun avis {{ currentStatus == 'pending' ? 'en attente' : '' }}.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card-footer bg-transparent pt-0">
            <div class="d-sm-flex justify-content-sm-between align-items-sm-center">
                <p class="mb-0 text-center text-sm-start">
                    Affichage de {{ totalReviews }} avis
                </p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
