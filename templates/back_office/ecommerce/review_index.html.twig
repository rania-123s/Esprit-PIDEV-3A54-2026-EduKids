{% extends 'back_office/ecommerce_base.html.twig' %}

{% block title %}Avis clients - Admin E-commerce{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-bold mb-0 ecommerce-admin-header"><i class="bi bi-chat-quote me-2 text-primary"></i>Avis clients</h1>
            <p class="small mb-0" style="color: #4b5563 !important;">Modérer les avis (approuver / rejeter).</p>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('ecommerce_admin_review_index', { status: 'pending' }) }}" class="btn {{ currentStatus == 'pending' ? 'btn-primary' : 'btn-outline-primary' }} rounded-pill">En attente</a>
            <a href="{{ path('ecommerce_admin_review_index', { status: 'all' }) }}" class="btn {{ currentStatus == 'all' ? 'btn-primary' : 'btn-outline-primary' }} rounded-pill">Tous</a>
        </div>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 border-start border-success border-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    <div class="card ecommerce-admin-card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-uppercase small" style="color: #1f2937 !important;">
                    <tr>
                        <th class="ps-4 py-3 border-0">Produit</th>
                        <th class="py-3 border-0">Client</th>
                        <th class="py-3 border-0">Note</th>
                        <th class="py-3 border-0">Commentaire</th>
                        <th class="py-3 border-0">Date</th>
                        <th class="py-3 border-0">Statut</th>
                        <th class="pe-4 py-3 border-0 text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for review in reviews %}
                        <tr>
                            <td class="ps-4 py-3">
                                <a href="{{ path('ecommerce_produit_show', { id: review.produit.id }) }}" class="fw-semibold text-decoration-none" style="color: #1f2937 !important;">{{ review.produit.nom }}</a>
                            </td>
                            <td class="py-3" style="color: #374151 !important;">{{ review.user.email }}</td>
                            <td class="py-3">
                                <span class="text-warning">{% for i in 1..5 %}<i class="bi bi-star{{ i <= review.rating ? '-fill' : '' }}"></i>{% endfor %}</span>
                            </td>
                            <td class="py-3 small" style="color: #4b5563 !important; max-width: 200px;">{{ review.comment|slice(0, 80) }}{% if review.comment|length > 80 %}...{% endif %}</td>
                            <td class="py-3 small" style="color: #4b5563 !important;">{{ review.createdAt|date('d/m/Y H:i') }}</td>
                            <td class="py-3">
                                {% if review.status == 'pending' %}
                                    <span class="badge bg-warning text-dark">En attente</span>
                                {% elseif review.status == 'approved' %}
                                    <span class="badge bg-success">Approuvé</span>
                                {% else %}
                                    <span class="badge bg-danger">Rejeté</span>
                                {% endif %}
                            </td>
                            <td class="pe-4 py-3 text-end">
                                {% if review.status == 'pending' %}
                                    <form method="post" action="{{ path('ecommerce_admin_review_approve', { id: review.id }) }}" class="d-inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('review_approve' ~ review.id) }}">
                                        <button type="submit" class="btn btn-sm btn-success rounded-pill">Approuver</button>
                                    </form>
                                    <form method="post" action="{{ path('ecommerce_admin_review_reject', { id: review.id }) }}" class="d-inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('review_reject' ~ review.id) }}">
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill">Rejeter</button>
                                    </form>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" class="text-center py-5" style="color: #4b5563 !important;">
                                <i class="bi bi-chat-quote fs-1 d-block mb-3" style="opacity: .4;"></i>
                                Aucun avis {{ currentStatus == 'pending' ? 'en attente' : '' }}.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
