{% extends 'back_office/ecommerce_base.html.twig' %}

{% block title %}Gestion des Produits - Admin{% endblock %}

{% block body %}
<style>
    .ecom-produit-tuned .card {
        border-radius: 14px;
        overflow: hidden;
        animation: panelIn 0.45s ease both;
    }

    .ecom-produit-tuned .card-header {
        padding-top: 1rem;
        padding-bottom: 1rem;
    }

    .ecom-produit-tuned .form-control,
    .ecom-produit-tuned .form-select {
        border-radius: 10px;
    }

    .ecom-produit-tuned .table thead th {
        font-weight: 700;
        letter-spacing: 0.2px;
    }

    .ecom-produit-tuned .table tbody tr {
        transition: background-color 0.2s ease;
        animation: rowIn 0.35s ease both;
    }

    .ecom-produit-tuned .table tbody tr:hover {
        background-color: rgba(13, 110, 253, 0.04);
    }

    .ecom-produit-tuned .w-60px img {
        width: 56px;
        height: 56px;
        object-fit: cover;
        border: 1px solid rgba(0, 0, 0, 0.08);
    }

    .ecom-produit-tuned .results-meta {
        font-size: 0.85rem;
        color: #6c757d;
        animation: fadeInSoft 0.45s ease both;
    }

    .ecom-produit-tuned .row.mb-3 {
        animation: slideDownIn 0.45s ease both;
    }

    .ecom-produit-tuned .row.g-4.mb-4 > div {
        animation: riseIn 0.45s ease both;
    }

    .ecom-produit-tuned .row.g-4.mb-4 > div:nth-child(2) {
        animation-delay: 0.08s;
    }

    .ecom-produit-tuned .row.g-4.mb-4 > div:nth-child(3) {
        animation-delay: 0.16s;
    }

    .ecom-produit-tuned .card-header .fa-search {
        transition: transform 0.2s ease;
    }

    .ecom-produit-tuned .card-header .btn:hover .fa-search {
        transform: scale(1.15);
    }

    .ecom-produit-tuned .btn-outline-secondary {
        animation: pulseSoft 1.7s ease-in-out infinite;
    }

    .ecom-produit-tuned .table tbody tr:nth-child(1) { animation-delay: 0.02s; }
    .ecom-produit-tuned .table tbody tr:nth-child(2) { animation-delay: 0.05s; }
    .ecom-produit-tuned .table tbody tr:nth-child(3) { animation-delay: 0.08s; }
    .ecom-produit-tuned .table tbody tr:nth-child(4) { animation-delay: 0.11s; }
    .ecom-produit-tuned .table tbody tr:nth-child(5) { animation-delay: 0.14s; }

    @keyframes slideDownIn {
        from { opacity: 0; transform: translateY(-8px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @keyframes riseIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @keyframes panelIn {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @keyframes fadeInSoft {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    @keyframes rowIn {
        from { opacity: 0; transform: translateX(8px); }
        to { opacity: 1; transform: translateX(0); }
    }

    @keyframes pulseSoft {
        0%, 100% { box-shadow: 0 0 0 0 rgba(108, 117, 125, 0.12); }
        50% { box-shadow: 0 0 0 6px rgba(108, 117, 125, 0.04); }
    }

    @media (max-width: 768px) {
        .ecom-produit-tuned .card-header .row > div {
            width: 100%;
        }
    }
</style>

{% set totalProduits = produits|length %}
{% set produitsWithImage = 0 %}
{% for produit in produits %}
    {% if produit.imageUrl %}
        {% set produitsWithImage = produitsWithImage + 1 %}
    {% endif %}
{% endfor %}

<div class="ecom-produit-tuned">
    <div class="row mb-3">
        <div class="col-12 d-sm-flex justify-content-between align-items-center">
            <h1 class="h3 mb-2 mb-sm-0 ecommerce-admin-header">Produits</h1>
            <a href="{{ path('ecommerce_admin_produit_new') }}" class="btn btn-sm btn-primary mb-0">Nouveau produit</a>
        </div>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 border-start border-success border-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    <div class="row g-4 mb-4">
        <div class="col-sm-6 col-lg-4">
            <div class="text-center p-4 bg-primary bg-opacity-10 border border-primary rounded-3">
                <h6>Total Produits</h6>
                <h2 class="mb-0 fs-1 text-primary">{{ totalProduits }}</h2>
            </div>
        </div>
        <div class="col-sm-6 col-lg-4">
            <div class="text-center p-4 bg-success bg-opacity-10 border border-success rounded-3">
                <h6>Produits avec image</h6>
                <h2 class="mb-0 fs-1 text-success">{{ produitsWithImage }}</h2>
            </div>
        </div>
        <div class="col-sm-6 col-lg-4">
            <div class="text-center p-4 bg-warning bg-opacity-15 border border-warning rounded-3">
                <h6>Categories disponibles</h6>
                <h2 class="mb-0 fs-1 text-warning">{{ categories|length }}</h2>
            </div>
        </div>
    </div>

    <div class="card bg-transparent border">
        <div class="card-header bg-light border-bottom">
            <form method="get" action="{{ path('ecommerce_admin_produit_index') }}">
                <div class="row g-3 align-items-center justify-content-between">
                    <div class="col-md-4">
                        <div class="rounded position-relative">
                            <input class="form-control bg-body" type="search" name="q" placeholder="Recherche nom ou description..." aria-label="Search" value="{{ searchQuery ?? '' }}">
                            <button type="submit" class="btn bg-transparent px-2 py-0 position-absolute top-50 end-0 translate-middle-y me-2" aria-label="Rechercher">
                                <i class="fas fa-search fs-6 text-primary"></i>
                            </button>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <select name="category" class="form-select js-choice border-0 z-index-9">
                            <option value="">Toutes les categories</option>
                            {% for cat in categories %}
                                <option value="{{ cat.id }}" {{ (filterCategoryId ?? '') == cat.id ? 'selected' : '' }}>{{ cat.nom }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-2">
                        <select name="sort" class="form-select js-choice border-0 z-index-9">
                            <option value="nom" {{ sort == 'nom' ? 'selected' : '' }}>Nom</option>
                            <option value="prix" {{ sort == 'prix' ? 'selected' : '' }}>Prix</option>
                            <option value="category" {{ sort == 'category' ? 'selected' : '' }}>Categorie</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <select name="order" class="form-select js-choice border-0 z-index-9">
                            <option value="ASC" {{ order == 'ASC' ? 'selected' : '' }}>ASC</option>
                            <option value="DESC" {{ order == 'DESC' ? 'selected' : '' }}>DESC</option>
                        </select>
                    </div>
                    <div class="col-md-1 text-md-end">
                        {% if searchQuery or filterCategoryId or sort != 'nom' or order != 'ASC' %}
                            <a href="{{ path('ecommerce_admin_produit_index') }}" class="btn btn-sm btn-outline-secondary">Reset</a>
                        {% else %}
                            <button type="submit" class="btn btn-sm btn-primary">OK</button>
                        {% endif %}
                    </div>
                </div>
            </form>

            <div class="results-meta mt-2">
                {{ totalProduits }} resultat(s)
                {% if searchQuery %}
                    | recherche: "{{ searchQuery }}"
                {% endif %}
                {% if filterCategoryId %}
                    | categorie: {{ filterCategoryId }}
                {% endif %}
                {% if sort %}
                    | tri: {{ sort }} {{ order }}
                {% endif %}
            </div>
        </div>

        <div class="card-body">
            <div class="table-responsive border-0 rounded-3">
                <table class="table table-dark-gray align-middle p-4 mb-0 table-hover">
                    <thead>
                        <tr>
                            <th scope="col" class="border-0 rounded-start">Produit</th>
                            <th scope="col" class="border-0">Categorie</th>
                            <th scope="col" class="border-0">Prix</th>
                            <th scope="col" class="border-0 rounded-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for produit in produits %}
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center position-relative">
                                        <div class="w-60px">
                                            {% if produit.imageUrl %}
                                                <img src="{{ produit.imageUrl }}" class="rounded" alt="">
                                            {% else %}
                                                <div class="rounded bg-light d-flex align-items-center justify-content-center text-muted" style="width: 56px; height: 56px; border: 1px solid rgba(0, 0, 0, 0.08);">
                                                    <i class="bi bi-image fs-5"></i>
                                                </div>
                                            {% endif %}
                                        </div>
                                        <div class="ms-2">
                                            <h6 class="table-responsive-title mb-0">{{ produit.nom }}</h6>
                                            <div class="small text-truncate" style="max-width: 250px; color: #4b5563 !important;">{{ produit.description|striptags }}</div>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="badge text-bg-primary">{{ produit.category ? produit.category.nom : 'Non classe' }}</span></td>
                                <td class="fw-bold text-dark">{{ (produit.prix / 100)|number_format(2, ',', ' ') }} EUR</td>
                                <td>
                                    <a href="{{ path('ecommerce_admin_produit_edit', { id: produit.id }) }}" class="btn btn-sm btn-warning-soft me-1 mb-1 mb-md-0">Modifier</a>
                                    <form method="post" action="{{ path('ecommerce_admin_produit_delete', { id: produit.id }) }}" style="display:inline;" onsubmit="return confirm('Supprimer ce produit ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ produit.id) }}">
                                        <button type="submit" class="btn btn-sm btn-danger-soft mb-0">Supprimer</button>
                                    </form>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="4">Aucun produit trouve.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card-footer bg-transparent pt-0">
            <div class="d-sm-flex justify-content-sm-between align-items-sm-center">
                <p class="mb-0 text-center text-sm-start">
                    Affichage de {{ totalProduits }} produit(s)
                </p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
