{% extends 'back_office/ecommerce_base.html.twig' %}

{% block title %}Gestion des Commandes - Admin{% endblock %}

{% block body %}
<style>
    .ecom-commande-tuned .card {
        border-radius: 14px;
        overflow: hidden;
        animation: panelIn 0.45s ease both;
    }

    .ecom-commande-tuned .card-header {
        padding-top: 1rem;
        padding-bottom: 1rem;
    }

    .ecom-commande-tuned .form-control,
    .ecom-commande-tuned .form-select {
        border-radius: 10px;
    }

    .ecom-commande-tuned .table thead th {
        font-weight: 700;
        letter-spacing: 0.2px;
    }

    .ecom-commande-tuned .table tbody tr {
        transition: background-color 0.2s ease;
        animation: rowIn 0.35s ease both;
    }

    .ecom-commande-tuned .table tbody tr:hover {
        background-color: rgba(13, 110, 253, 0.04);
    }

    .ecom-commande-tuned .results-meta {
        font-size: 0.85rem;
        color: #6c757d;
        animation: fadeInSoft 0.45s ease both;
    }

    .ecom-commande-tuned .row.mb-3 {
        animation: slideDownIn 0.45s ease both;
    }

    .ecom-commande-tuned .row.g-4.mb-4 > div {
        animation: riseIn 0.45s ease both;
    }

    .ecom-commande-tuned .row.g-4.mb-4 > div:nth-child(2) {
        animation-delay: 0.08s;
    }

    .ecom-commande-tuned .row.g-4.mb-4 > div:nth-child(3) {
        animation-delay: 0.16s;
    }

    .ecom-commande-tuned .card-header .fa-search {
        transition: transform 0.2s ease;
    }

    .ecom-commande-tuned .card-header .btn:hover .fa-search {
        transform: scale(1.15);
    }

    .ecom-commande-tuned .btn-outline-secondary {
        animation: pulseSoft 1.7s ease-in-out infinite;
    }

    .ecom-commande-tuned .table tbody tr:nth-child(1) { animation-delay: 0.02s; }
    .ecom-commande-tuned .table tbody tr:nth-child(2) { animation-delay: 0.05s; }
    .ecom-commande-tuned .table tbody tr:nth-child(3) { animation-delay: 0.08s; }
    .ecom-commande-tuned .table tbody tr:nth-child(4) { animation-delay: 0.11s; }
    .ecom-commande-tuned .table tbody tr:nth-child(5) { animation-delay: 0.14s; }

    @keyframes slideDownIn {
        from { opacity: 0; transform: translateY(-8px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @keyframes riseIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @keyframes panelIn {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @keyframes fadeInSoft {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    @keyframes rowIn {
        from { opacity: 0; transform: translateX(8px); }
        to { opacity: 1; transform: translateX(0); }
    }

    @keyframes pulseSoft {
        0%, 100% { box-shadow: 0 0 0 0 rgba(108, 117, 125, 0.12); }
        50% { box-shadow: 0 0 0 6px rgba(108, 117, 125, 0.04); }
    }

    @media (max-width: 768px) {
        .ecom-commande-tuned .card-header .row > div {
            width: 100%;
        }
    }
</style>

{% set totalCommandes = commandes|length %}
{% set totalMontant = 0 %}
{% set confirmedCount = 0 %}
{% for commande in commandes %}
    {% set totalMontant = totalMontant + (commande.montantTotal ?? 0) %}
    {% if commande.statut in ['confirme', 'paye', 'livre'] %}
        {% set confirmedCount = confirmedCount + 1 %}
    {% endif %}
{% endfor %}
{% set pendingCount = totalCommandes - confirmedCount %}

<div class="ecom-commande-tuned">
    <div class="row mb-3">
        <div class="col-12 d-sm-flex justify-content-between align-items-center">
            <h1 class="h3 mb-2 mb-sm-0 ecommerce-admin-header">Commandes</h1>
        </div>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 border-start border-success border-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    <div class="row g-4 mb-4">
        <div class="col-sm-6 col-lg-4">
            <div class="text-center p-4 bg-primary bg-opacity-10 border border-primary rounded-3">
                <h6>Total Commandes</h6>
                <h2 class="mb-0 fs-1 text-primary">{{ totalCommandes }}</h2>
            </div>
        </div>
        <div class="col-sm-6 col-lg-4">
            <div class="text-center p-4 bg-success bg-opacity-10 border border-success rounded-3">
                <h6>Commandes traitees</h6>
                <h2 class="mb-0 fs-1 text-success">{{ confirmedCount }}</h2>
            </div>
        </div>
        <div class="col-sm-6 col-lg-4">
            <div class="text-center p-4 bg-warning bg-opacity-15 border border-warning rounded-3">
                <h6>Montant total</h6>
                <h2 class="mb-0 fs-1 text-warning">{{ (totalMontant / 100)|number_format(2, ',', ' ') }} EUR</h2>
            </div>
        </div>
    </div>

    <div class="card bg-transparent border">
        <div class="card-header bg-light border-bottom">
            <form method="get" action="{{ path('ecommerce_admin_commande_index') }}">
                <div class="row g-3 align-items-center justify-content-between">
                    <div class="col-md-5">
                        <div class="rounded position-relative">
                            <input class="form-control bg-body" type="search" name="q" placeholder="Recherche email, statut, ID..." aria-label="Search" value="{{ searchQuery ?? '' }}">
                            <button type="submit" class="btn bg-transparent px-2 py-0 position-absolute top-50 end-0 translate-middle-y me-2" aria-label="Rechercher">
                                <i class="fas fa-search fs-6 text-primary"></i>
                            </button>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <select name="sort" class="form-select js-choice border-0 z-index-9">
                            <option value="id" {{ sort == 'id' ? 'selected' : '' }}>ID</option>
                            <option value="date" {{ sort == 'date' ? 'selected' : '' }}>Date</option>
                            <option value="montant" {{ sort == 'montant' ? 'selected' : '' }}>Montant</option>
                            <option value="statut" {{ sort == 'statut' ? 'selected' : '' }}>Statut</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <select name="order" class="form-select js-choice border-0 z-index-9">
                            <option value="ASC" {{ order == 'ASC' ? 'selected' : '' }}>ASC</option>
                            <option value="DESC" {{ order == 'DESC' ? 'selected' : '' }}>DESC</option>
                        </select>
                    </div>
                    <div class="col-md-1 text-md-end">
                        {% if searchQuery or sort != 'date' or order != 'DESC' %}
                            <a href="{{ path('ecommerce_admin_commande_index') }}" class="btn btn-sm btn-outline-secondary">Reset</a>
                        {% else %}
                            <button type="submit" class="btn btn-sm btn-primary">OK</button>
                        {% endif %}
                    </div>
                </div>
            </form>

            <div class="results-meta mt-2">
                {{ totalCommandes }} resultat(s)
                {% if searchQuery %}
                    | recherche: "{{ searchQuery }}"
                {% endif %}
                {% if sort %}
                    | tri: {{ sort }} {{ order }}
                {% endif %}
                | en attente: {{ pendingCount }}
            </div>
        </div>

        <div class="card-body">
            <div class="table-responsive border-0 rounded-3">
                <table class="table table-dark-gray align-middle p-4 mb-0 table-hover">
                    <thead>
                        <tr>
                            <th scope="col" class="border-0 rounded-start">ID</th>
                            <th scope="col" class="border-0">Client</th>
                            <th scope="col" class="border-0">Date</th>
                            <th scope="col" class="border-0">Montant</th>
                            <th scope="col" class="border-0">Statut</th>
                            <th scope="col" class="border-0 rounded-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for commande in commandes %}
                            <tr>
                                <td class="fw-bold text-dark">#{{ commande.id }}</td>
                                <td>
                                    <div class="d-flex align-items-center position-relative">
                                        <span class="rounded-circle bg-primary bg-opacity-10 text-primary d-inline-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                                            <i class="bi bi-person-fill"></i>
                                        </span>
                                        <h6 class="table-responsive-title mb-0 ms-2">{{ commande.user ? commande.user.email : 'Utilisateur inconnu' }}</h6>
                                    </div>
                                </td>
                                <td>{{ commande.date ? commande.date|date('d/m/Y H:i') : '-' }}</td>
                                <td class="fw-bold">{{ (commande.montantTotal / 100)|number_format(2, ',', ' ') }} EUR</td>
                                <td>
                                    {% set badgeClass = 'bg-secondary' %}
                                    {% if commande.statut in ['confirme', 'paye'] %}
                                        {% set badgeClass = 'bg-success' %}
                                    {% elseif commande.statut == 'livre' %}
                                        {% set badgeClass = 'bg-info' %}
                                    {% elseif commande.statut in ['panier', 'en_attente'] %}
                                        {% set badgeClass = 'bg-warning' %}
                                    {% elseif commande.statut in ['annule', 'rejete'] %}
                                        {% set badgeClass = 'bg-danger' %}
                                    {% endif %}
                                    <span class="badge {{ badgeClass }} rounded-pill px-3">{{ commande.statut|capitalize }}</span>
                                </td>
                                <td>
                                    <a href="{{ path('ecommerce_admin_commande_show', { id: commande.id }) }}" class="btn btn-sm btn-primary-soft me-1 mb-1 mb-md-0">Detail</a>
                                    {% if commande.statut not in ['confirme', 'rejete', 'annule'] %}
                                        <form method="post" action="{{ path('ecommerce_admin_commande_confirm', { id: commande.id }) }}" style="display:inline;" onsubmit="return confirm('Confirmer cette commande ?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('confirm' ~ commande.id) }}">
                                            <button class="btn btn-sm btn-success-soft me-1 mb-1 mb-md-0">Confirmer</button>
                                        </form>
                                        <form method="post" action="{{ path('ecommerce_admin_commande_reject', { id: commande.id }) }}" style="display:inline;" onsubmit="return confirm('Rejeter cette commande ?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('reject' ~ commande.id) }}">
                                            <button class="btn btn-sm btn-warning-soft me-1 mb-1 mb-md-0">Rejeter</button>
                                        </form>
                                    {% endif %}
                                    <form method="post" action="{{ path('ecommerce_admin_commande_delete', { id: commande.id }) }}" style="display:inline;" onsubmit="return confirm('Supprimer definitivement cette commande ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ commande.id) }}">
                                        <button class="btn btn-sm btn-danger-soft mb-0">Supprimer</button>
                                    </form>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6">Aucune commande trouvee.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card-footer bg-transparent pt-0">
            <div class="d-sm-flex justify-content-sm-between align-items-sm-center">
                <p class="mb-0 text-center text-sm-start">
                    Affichage de {{ totalCommandes }} commande(s)
                </p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
