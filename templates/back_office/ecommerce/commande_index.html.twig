{% extends 'back_office/ecommerce_base.html.twig' %}

{% block title %}Gestion des Commandes - Admin{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-bold mb-0 ecommerce-admin-header"><i class="bi bi-cart-check me-2 text-primary"></i>Gestion des Commandes</h1>
            <p class="small mb-0" style="color: #4b5563 !important;">Suivez et gérez les commandes clients.</p>
        </div>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 border-start border-success border-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    <div class="card ecommerce-admin-card border-0 shadow-sm mb-4">
        <div class="card-body bg-light rounded-3 p-3">
             <form method="get" action="{{ path('ecommerce_admin_commande_index') }}" class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label class="form-label fw-semibold small text-uppercase" style="color: #374151 !important;">Recherche</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="q" class="form-control border-start-0" value="{{ searchQuery ?? '' }}" placeholder="Email, ID commande...">
                    </div>
                </div>
                <div class="col-md-3">
                     <label class="form-label fw-semibold small text-uppercase" style="color: #374151 !important;">Tri</label>
                     <div class="input-group">
                        <select name="sort" class="form-select">
                            <option value="id" {{ sort == 'id' ? 'selected' : '' }}>ID</option>
                            <option value="date" {{ sort == 'date' ? 'selected' : '' }}>Date</option>
                            <option value="montant" {{ sort == 'montant' ? 'selected' : '' }}>Montant</option>
                            <option value="statut" {{ sort == 'statut' ? 'selected' : '' }}>Statut</option>
                        </select>
                        <select name="order" class="form-select" style="max-width: 80px;">
                            <option value="ASC" {{ order == 'ASC' ? 'selected' : '' }}>Croissant</option>
                            <option value="DESC" {{ order == 'DESC' ? 'selected' : '' }}>Décroissant</option>
                        </select>
                     </div>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100 fw-semibold rounded-pill"><i class="bi bi-funnel me-1"></i> Filtrer</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card ecommerce-admin-card border-0 shadow-sm">
        <div class="table-responsive">
             <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-uppercase small" style="color: #1f2937 !important;">
                    <tr>
                        <th class="ps-4 py-3 border-0 rounded-start">ID</th>
                        <th class="py-3 border-0">Client</th>
                        <th class="py-3 border-0">Date</th>
                        <th class="py-3 border-0">Montant</th>
                        <th class="py-3 border-0">Statut</th>
                        <th class="pe-4 py-3 border-0 rounded-end text-end">Actions</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    {% for commande in commandes %}
                        <tr>
                            <td class="ps-4 py-3 fw-bold text-dark">
                                #{{ commande.id }}
                            </td>
                            <td class="py-3">
                                <div class="d-flex align-items-center">
                                    <div class="avatar avatar-sm rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px;">
                                        <i class="bi bi-person-fill"></i>
                                    </div>
                                    <span class="small fw-semibold">{{ commande.user ? commande.user.email : 'Utilisateur inconnu' }}</span>
                                </div>
                            </td>
                            <td class="py-3 small" style="color: #4b5563 !important;">
                                {{ commande.date ? commande.date|date('d/m/Y H:i') : '-' }}
                            </td>
                            <td class="py-3 fw-bold">
                                {{ (commande.montantTotal / 100)|number_format(2, ',', ' ') }} €
                            </td>
                            <td class="py-3">
                                {% set badgeClass = 'bg-secondary' %}
                                {% if commande.statut == 'confirme' or commande.statut == 'paye' %}
                                    {% set badgeClass = 'bg-success' %}
                                {% elseif commande.statut == 'livre' %}
                                    {% set badgeClass = 'bg-info' %}
                                {% elseif commande.statut == 'panier' or commande.statut == 'en_attente' %}
                                    {% set badgeClass = 'bg-warning' %}
                                {% elseif commande.statut == 'annule' or commande.statut == 'rejete' %}
                                    {% set badgeClass = 'bg-danger' %}
                                {% endif %}
                                <span class="badge {{ badgeClass }} rounded-pill px-3">{{ commande.statut|capitalize }}</span>
                            </td>
                            <td class="pe-4 py-3 text-end">
                                <div class="btn-group">
                                    <a href="{{ path('ecommerce_admin_commande_show', { id: commande.id }) }}" class="btn btn-sm btn-outline-secondary" title="Détails">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                     {% if commande.statut != 'confirme' and commande.statut != 'rejete' and commande.statut != 'annule' %}
                                         <form method="post" action="{{ path('ecommerce_admin_commande_confirm', { id: commande.id }) }}" class="d-inline" onsubmit="return confirm('Confirmer cette commande ?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('confirm' ~ commande.id) }}">
                                            <button class="btn btn-sm btn-outline-success" title="Confirmer"><i class="bi bi-check-lg"></i></button>
                                        </form>
                                        <form method="post" action="{{ path('ecommerce_admin_commande_reject', { id: commande.id }) }}" class="d-inline" onsubmit="return confirm('Rejeter cette commande ?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('reject' ~ commande.id) }}">
                                            <button class="btn btn-sm btn-outline-danger" title="Rejeter"><i class="bi bi-x-lg"></i></button>
                                        </form>
                                     {% endif %}
                                    <form method="post" action="{{ path('ecommerce_admin_commande_delete', { id: commande.id }) }}" class="d-inline" onsubmit="return confirm('Supprimer définitivement cette commande ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ commande.id) }}">
                                        <button class="btn btn-sm btn-outline-dark border-start-0" title="Supprimer">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="text-center py-5" style="color: #4b5563 !important;">
                                <i class="bi bi-cart-x fs-1 d-block mb-3" style="opacity: .4;"></i>
                                Aucune commande trouvée.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        <div class="card-footer bg-white py-3 border-0">
             <small style="color: #4b5563 !important;">{{ commandes|length }} commande(s) affichée(s)</small>
        </div>
    </div>
</div>
{% endblock %}
