{% extends 'ecommerce/base_ecommerce.html.twig' %}

{% block title %}Mon Panier - E-commerce Éducatif{% endblock %}

{% block ecommerce_content %}
<div class="container py-5">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="h3 fw-bold mb-0" style="color: #1e3a5f;">Mon Panier</h1>
        </div>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show shadow-sm rounded-3">{{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
    {% for message in app.flashes('warning') %}
        <div class="alert alert-warning alert-dismissible fade show shadow-sm rounded-3">{{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    {% if panier.items is empty %}
        <div class="text-center py-5 bg-white rounded-3 shadow-sm" style="border: 1px solid #e5e7eb;">
            <div class="mb-4">
                <i class="bi bi-cart-x fs-1" style="color: #9ca3af !important; opacity: .6;"></i>
            </div>
            <h4 class="mb-3" style="color: #374151 !important;">Votre panier est vide</h4>
            <a href="{{ path('ecommerce_catalogue') }}" class="btn btn-primary rounded-pill px-4">Découvrir nos produits</a>
        </div>
    {% else %}
        <div class="row g-4">
            <!-- Cart Items -->
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-3 overflow-hidden" style="border: 1px solid #e5e7eb !important;">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0 table-hover">
                            <thead class="bg-light">
                                <tr>
                                    <th class="border-0 py-3 ps-4 fw-semibold" style="color: #1f2937 !important;">Produit</th>
                                    <th class="border-0 py-3 fw-semibold" style="color: #1f2937 !important;">Prix</th>
                                    <th class="border-0 py-3 fw-semibold" style="color: #1f2937 !important;">Quantité</th>
                                    <th class="border-0 py-3 text-end pe-4 fw-semibold" style="color: #1f2937 !important;">Total</th>
                                    <th class="border-0 py-3"></th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for item in panier.items %}
                                    <tr>
                                        <td class="ps-4 py-3">
                                            <div class="d-flex align-items-center">
                                                {% if item.image_url %}
                                                    <img src="{{ item.image_url }}" class="rounded me-3" alt="{{ item.produit.nom }}" style="width: 48px; height: 48px; object-fit: cover;">
                                                {% else %}
                                                    <div class="rounded me-3 d-flex align-items-center justify-content-center bg-light text-muted" style="width: 48px; height: 48px;">
                                                        <i class="bi bi-image"></i>
                                                    </div>
                                                {% endif %}
                                                <div>
                                                    <div class="fw-semibold" style="color: #1f2937 !important;">{{ item.produit.nom }}</div>
                                                    <div class="small" style="color: #4b5563 !important;">{{ item.produit.category ? item.produit.category.nom : 'Divers' }}</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td>{{ (item.produit.prix / 100)|number_format(2, ',', ' ') }} €</td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <form method="post" action="{{ path('ecommerce_panier_retirer', { id: item.produit.id }) }}">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('panier_retirer_' ~ item.produit.id) }}">
                                                    <button type="submit" class="btn btn-sm btn-outline-secondary rounded-circle" style="width: 24px; height: 24px; padding: 0; line-height: 22px;">-</button>
                                                </form>
                                                <span class="mx-2 fw-semibold">{{ item.quantite }}</span>
                                                <form method="post" action="{{ path('ecommerce_panier_ajouter', { id: item.produit.id }) }}">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('panier_ajouter_' ~ item.produit.id) }}">
                                                    <input type="hidden" name="quantite" value="1">
                                                    <button type="submit" class="btn btn-sm btn-outline-primary rounded-circle" style="width: 24px; height: 24px; padding: 0; line-height: 22px;">+</button>
                                                </form>
                                            </div>
                                        </td>
                                        <td class="text-end pe-4 fw-bold">
                                            {{ (item.sous_total / 100)|number_format(2, ',', ' ') }} €
                                        </td>
                                        <td class="text-end">
                                            <form method="post" action="{{ path('ecommerce_panier_supprimer', { id: item.produit.id }) }}">
                                                <input type="hidden" name="_token" value="{{ csrf_token('panier_supprimer_' ~ item.produit.id) }}">
                                                <button type="submit" class="btn btn-link text-danger p-0" title="Supprimer">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="mt-3">
                    <a href="{{ path('ecommerce_catalogue') }}" class="btn btn-outline-secondary rounded-pill">
                        <i class="bi bi-arrow-left me-2"></i> Continuer mes achats
                    </a>
                </div>
            </div>

            <!-- Summary -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-3" style="border: 1px solid #e5e7eb !important;">
                    <div class="card-body p-4">
                        <h5 class="card-title fw-bold mb-4" style="color: #1f2937 !important;">Résumé</h5>
                        <div class="d-flex justify-content-between mb-2">
                            <span style="color: #4b5563 !important;">Sous-total</span>
                            <span class="fw-semibold" style="color: #1f2937 !important;">{{ (panier.total / 100)|number_format(2, ',', ' ') }} €</span>
                        </div>
                        <div class="d-flex justify-content-between mb-4">
                            <span style="color: #4b5563 !important;">Livraison</span>
                            <span class="text-success fw-semibold">Gratuite</span>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between mb-4">
                            <span class="h5 fw-bold">Total</span>
                            <span class="h5 fw-bold text-primary">{{ (panier.total / 100)|number_format(2, ',', ' ') }} €</span>
                        </div>
                        {% if app.user %}
                            <a href="{{ path('ecommerce_commande_recapitulatif') }}" class="btn btn-primary w-100 rounded-pill py-2 fw-semibold">
                                Commander <i class="bi bi-arrow-right ms-2"></i>
                            </a>
                        {% else %}
                            <a href="{{ path('app_login') }}" class="btn btn-primary w-100 rounded-pill py-2 fw-semibold">
                                Se connecter pour commander
                            </a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}
