{% extends 'ecommerce/base_ecommerce.html.twig' %}

{% block title %}Catalogue - E-commerce Educatif{% endblock %}

{% block ecommerce_content %}
<section class="bg-blue align-items-center d-flex" style="background:url('{{ asset('assets/images/pattern/04.png') }}') no-repeat center center; background-size:cover;">
    <div class="container">
        <div class="row">
            <div class="col-12 text-center">
                <h1 class="text-white">Catalogue E-commerce</h1>
                <div class="d-flex justify-content-center">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb breadcrumb-dark breadcrumb-dots mb-0">
                            <li class="breadcrumb-item"><a href="{{ path('home') }}">Home</a></li>
                            <li class="breadcrumb-item active" aria-current="page">E-commerce</li>
                        </ol>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row mb-4 align-items-center g-3">
            <div class="col-xl-9">
                <form method="get" action="{{ path('ecommerce_catalogue') }}" class="border rounded p-3">
                    <div class="row g-2">
                        <div class="col-lg-4">
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="bi bi-search"></i></span>
                                <input
                                    type="text"
                                    name="q"
                                    id="ecommerce-search-query"
                                    class="form-control border-start-0 ps-0"
                                    value="{{ searchQuery ?? '' }}"
                                    placeholder="Produit..."
                                    autocomplete="off"
                                >
                                <button type="button" id="ecommerce-voice-search-btn" class="btn btn-outline-secondary border-start-0" title="Recherche vocale" aria-label="Recherche vocale">
                                    <i class="bi bi-mic-fill"></i>
                                </button>
                            </div>
                        </div>
                        <div class="col-md-4 col-lg-2">
                            <select name="category" class="form-select">
                                <option value="">Categorie</option>
                                {% for cat in categories %}
                                    <option value="{{ cat.id }}" {{ (filter_category_id ?? '') == cat.id ? 'selected' : '' }}>{{ cat.nom }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-3 col-lg-2">
                            <input type="number" name="prix_min" class="form-control" value="{{ filter_prix_min ?? '' }}" min="0" step="0.01" placeholder="Prix min">
                        </div>
                        <div class="col-md-3 col-lg-2">
                            <input type="number" name="prix_max" class="form-control" value="{{ filter_prix_max ?? '' }}" min="0" step="0.01" placeholder="Prix max">
                        </div>
                        <div class="col-md-6 col-lg-1">
                            <select name="sort" class="form-select">
                                <option value="nom" {{ sort == 'nom' ? 'selected' : '' }}>Nom</option>
                                <option value="prix" {{ sort == 'prix' ? 'selected' : '' }}>Prix</option>
                            </select>
                        </div>
                        <div class="col-md-6 col-lg-1">
                            <select name="order" class="form-select">
                                <option value="ASC" {{ order == 'ASC' ? 'selected' : '' }}>ASC</option>
                                <option value="DESC" {{ order == 'DESC' ? 'selected' : '' }}>DESC</option>
                            </select>
                        </div>
                    </div>
                    <div class="d-flex justify-content-end gap-2 mt-2">
                        <a href="{{ path('ecommerce_catalogue') }}" class="btn btn-outline-secondary btn-sm">Reset</a>
                        <button type="submit" class="btn btn-primary btn-sm px-4">Appliquer</button>
                    </div>
                </form>
            </div>
            <div class="col-xl-3 d-flex justify-content-xl-end align-items-center gap-2">
                <p class="mb-0 text-end">{{ produits|length }} produit(s)</p>
                <a href="{{ path('ecommerce_panier') }}" class="btn btn-outline-primary btn-sm rounded-pill px-3">
                    <i class="bi bi-cart3 me-1"></i>Panier
                </a>
            </div>
        </div>

        <div class="row g-4">
            {% for produit in produits %}
                {% set ratingInfo = ratingByProduit[produit.id] is defined ? ratingByProduit[produit.id] : { avg: 0, count: 0 } %}
                {% set produitImageUrl = productImageUrls[produit.id]|default(produit.imageUrl) %}
                <div class="col-sm-6 col-xl-4">
                    <div class="card shadow h-100 ecommerce-card">
                        {% if produitImageUrl %}
                            <img src="{{ produitImageUrl }}" class="card-img-top" alt="{{ produit.nom }}" style="height:220px; object-fit:cover;">
                        {% else %}
                            <div class="d-flex align-items-center justify-content-center bg-light text-muted" style="height:220px;">
                                <i class="bi bi-image fs-1"></i>
                            </div>
                        {% endif %}

                        <div class="card-body pb-0">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="badge bg-purple bg-opacity-10 text-purple">{{ produit.category ? produit.category.nom : 'Divers' }}</span>
                                <span class="small text-muted">
                                    {% if ratingInfo.count > 0 %}
                                        {{ ratingInfo.avg|number_format(1, ',', ' ') }}/5 ({{ ratingInfo.count }} avis)
                                    {% else %}
                                        0 avis
                                    {% endif %}
                                </span>
                            </div>
                            <h5 class="card-title mb-2">
                                <a href="{{ path('ecommerce_produit_show', { id: produit.id }) }}">{{ produit.nom }}</a>
                            </h5>
                            <p class="mb-2 text-truncate-2">
                                {{ produit.description|slice(0, 105) }}{% if produit.description|length > 105 %}...{% endif %}
                            </p>
                        </div>

                        <div class="card-footer pt-0 pb-3">
                            <hr>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="h5 fw-bold text-primary mb-0">{{ (produit.prix / 100)|number_format(2, ',', ' ') }} EUR</span>
                                <form method="post" action="{{ path('ecommerce_panier_ajouter', { id: produit.id }) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('panier_ajouter_' ~ produit.id) }}">
                                    <input type="hidden" name="quantite" value="1">
                                    <button type="submit" class="btn btn-sm btn-primary rounded-pill px-3">
                                        <i class="bi bi-cart-plus me-1"></i>Ajouter
                                    </button>
                                </form>
                            </div>
                            <a href="{{ path('ecommerce_produit_show', { id: produit.id }) }}" class="btn btn-primary-soft w-100 mt-3">Voir details</a>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12 text-center py-5">
                    <p class="mb-0">Aucun produit trouve.</p>
                </div>
            {% endfor %}
        </div>
    </div>
</section>

<style>
.ecommerce-card { transition: transform .2s ease, box-shadow .2s ease; }
.ecommerce-card:hover { transform: translateY(-3px); box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important; }
#ecommerce-voice-search-btn.recording { background: #dc3545; color: #fff; border-color: #dc3545; }
#ecommerce-voice-search-btn.recording i { animation: ecommerce-pulse 1s ease-in-out infinite; }
@keyframes ecommerce-pulse { 50% { opacity: 0.6; } }
</style>

<script>
(function () {
    var input = document.getElementById('ecommerce-search-query');
    var btn = document.getElementById('ecommerce-voice-search-btn');
    if (!input || !btn) return;

    var SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
    if (!SpeechRecognition) {
        btn.title = 'Recherche vocale non supportee';
        btn.disabled = true;
        return;
    }

    var recognition = new SpeechRecognition();
    recognition.continuous = false;
    recognition.interimResults = false;
    recognition.lang = 'fr-FR';

    btn.addEventListener('click', function () {
        if (btn.classList.contains('recording')) {
            recognition.stop();
            return;
        }
        btn.classList.add('recording');
        recognition.start();
    });

    recognition.onresult = function (e) {
        var transcript = (e.results[e.resultIndex][0].transcript || '').trim();
        if (transcript) {
            input.value = transcript;
            input.form && input.form.submit();
        }
        btn.classList.remove('recording');
    };

    recognition.onend = function () { btn.classList.remove('recording'); };
    recognition.onerror = function () { btn.classList.remove('recording'); };
})();
</script>
{% endblock %}
