{% extends 'ecommerce/base_ecommerce.html.twig' %}

{% block title %}Récapitulatif - E-commerce Éducatif{% endblock %}

{% block ecommerce_content %}
<div class="container py-5">
    <div class="row mb-5 text-center">
        <div class="col-12">
            <h1 class="h3 fw-bold mb-3" style="color: #1e3a5f;">Confirmation de la commande</h1>
            <p style="color: #4b5563 !important;">Vérifiez les détails de votre commande avant le paiement.</p>
        </div>
    </div>

    {% for message in app.flashes('warning') %}
        <div class="alert alert-warning shadow-sm rounded-3">{{ message }}</div>
    {% endfor %}

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-3 mb-4" style="border: 1px solid #e5e7eb !important;">
                <div class="card-header bg-white py-3 border-0">
                    <h5 class="mb-0 fw-bold" style="color: #1f2937 !important;"><i class="bi bi-cart3 me-2 text-primary"></i>Contenu de votre commande</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4 py-3 border-0 fw-semibold" style="color: #1f2937 !important;">Produit</th>
                                    <th class="py-3 border-0 fw-semibold" style="color: #1f2937 !important;">Quantité</th>
                                    <th class="pe-4 py-3 text-end border-0 fw-semibold" style="color: #1f2937 !important;">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for item in panier.items %}
                                    <tr>
                                        <td class="ps-4 py-3">
                                            <span class="fw-semibold" style="color: #1f2937 !important;">{{ item.produit.nom }}</span>
                                            <div class="small" style="color: #4b5563 !important;">{{ item.produit.category ? item.produit.category.nom : '' }}</div>
                                        </td>
                                        <td class="py-3">
                                            × {{ item.quantite }}
                                        </td>
                                        <td class="pe-4 py-3 text-end fw-semibold">
                                            {{ (item.sous_total / 100)|number_format(2, ',', ' ') }} €
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Payment Methods Mockup -->
            <div class="card border-0 shadow-sm rounded-3" style="border: 1px solid #e5e7eb !important;">
                <div class="card-header bg-white py-3 border-0">
                    <h5 class="mb-0 fw-bold" style="color: #1f2937 !important;"><i class="bi bi-credit-card me-2 text-primary"></i>Moyen de paiement</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3">
                        <div class="form-check border rounded px-3 py-2 bg-light w-100" style="border-color: #e5e7eb !important;">
                            <input class="form-check-input" type="radio" name="paymentMethod" id="card" checked>
                            <label class="form-check-label d-flex justify-content-between w-100 fw-semibold" for="card" style="color: #374151 !important;">
                                <span>Carte Bancaire</span>
                                <div>
                                    <i class="bi bi-credit-card-2-front"></i>
                                    <i class="bi bi-credit-card-2-back"></i>
                                </div>
                            </label>
                        </div>
                    </div>
                    <p class="small mt-2 mb-0" style="color: #4b5563 !important;"><i class="bi bi-lock-fill me-1"></i>Paiement 100% sécurisé (Simulation)</p>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-3 bg-light" style="border: 1px solid #e5e7eb !important;">
                <div class="card-body p-4">
                    <h5 class="card-title fw-bold mb-4" style="color: #1f2937 !important;">Total à payer</h5>
                    <div class="d-flex justify-content-between mb-3">
                        <span style="color: #4b5563 !important;">Sous-total</span>
                        <span style="color: #1f2937 !important;">{{ (panier.total / 100)|number_format(2, ',', ' ') }} €</span>
                    </div>
                    <div class="d-flex justify-content-between mb-4">
                        <span style="color: #4b5563 !important;">TVA (inclus)</span>
                        <span style="color: #1f2937 !important;">{{ (panier.total * 0.2 / 100)|number_format(2, ',', ' ') }} €</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between mb-4">
                        <span class="h4 fw-bold" style="color: #1f2937 !important;">Total</span>
                        <span class="h4 fw-bold text-primary">{{ (panier.total / 100)|number_format(2, ',', ' ') }} €</span>
                    </div>

                    <form method="post" action="{{ path('ecommerce_commande_valider') }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('ecommerce_commande_valider') }}">
                        <button type="submit" class="btn btn-success w-100 btn-lg rounded-pill fw-semibold shadow-sm mb-3">
                            <i class="bi bi-check-lg me-2"></i> Payer et confirmer
                        </button>
                    </form>
                    <a href="{{ path('ecommerce_panier') }}" class="btn btn-outline-secondary w-100 rounded-pill">Retour au panier</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
