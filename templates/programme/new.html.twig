{% extends 'base_backoffice.html.twig' %}

{% block title %}Nouveau Programme{% endblock %}

{% block body %}
<style>
    .programme-create-page {
        --ink: #0f172a;
        --muted: #5b667a;
        --line: #d7dfeb;
        --brand: #0ea5a3;
        --brand-dark: #0b7f7d;
        --hero-a: #0f766e;
        --hero-b: #155e75;
        --hero-c: #1d4ed8;
        font-family: "Heebo", sans-serif;
    }
    .create-hero {
        position: relative;
        overflow: hidden;
        border-radius: 24px;
        margin: 1.75rem 1rem 0;
        padding: 3rem 1.25rem;
        background: linear-gradient(120deg, var(--hero-a), var(--hero-b) 55%, var(--hero-c));
        color: #fff;
        box-shadow: 0 24px 60px rgba(2, 44, 34, 0.24);
    }
    .create-hero h1 { margin: 0; font-size: clamp(1.75rem, 4vw, 2.6rem); font-weight: 700; }
    .create-hero p { margin: 0.8rem 0 0; color: rgba(255, 255, 255, 0.92); }
    .create-shell { padding: 1.75rem 1rem 2.2rem; }
    .create-card {
        background: linear-gradient(170deg, rgba(255, 255, 255, 0.96), rgba(248, 251, 255, 0.96));
        border: 1px solid rgba(15, 23, 42, 0.07);
        border-radius: 24px;
        box-shadow: 0 22px 55px rgba(15, 23, 42, 0.1);
    }
    .create-card .card-body { padding: clamp(1.1rem, 2.8vw, 2.5rem); }
    .info-header { text-align: center; margin-bottom: 1.3rem; }
    .info-kicker {
        display: inline-flex; align-items: center; gap: 0.35rem;
        padding: 0.3rem 0.7rem; border-radius: 999px;
        background: rgba(14, 165, 163, 0.12); color: #0d7e7b;
        font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
        margin-bottom: 0.55rem;
    }
    .create-heading { color: var(--ink); font-size: clamp(1.2rem, 2.5vw, 1.6rem); font-weight: 700; margin-bottom: 0.35rem; }
    .info-subtitle { margin: 0; color: var(--muted); font-size: 0.9rem; }
    .form-section {
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 16px;
        background: #fff;
        padding: 1rem;
    }
    .form-section-title {
        margin: 0 0 0.75rem;
        font-size: 1rem;
        font-weight: 700;
        color: var(--ink);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .field-label { color: var(--ink); font-size: 0.94rem; font-weight: 700; margin-bottom: 0.45rem; }
    .modern-input {
        border: 1px solid var(--line);
        border-radius: 14px;
        padding: 0.82rem 0.95rem;
        font-size: 0.96rem;
        color: var(--ink);
        background: #fff;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }
    .modern-input:focus { border-color: rgba(14, 165, 163, 0.65); box-shadow: 0 0 0 4px rgba(14, 165, 163, 0.14); }
    .modern-input.is-invalid { border-color: #dc3545; box-shadow: none; }
    .form-note { margin-top: 0.4rem; color: var(--muted); font-size: 0.83rem; }
    .error-text { margin-top: 0.45rem; color: #dc3545; font-size: 0.86rem; }
    .ai-assistant-box { border-style: dashed; border-color: rgba(14, 165, 163, 0.45); background: rgba(14, 165, 163, 0.05); }
    .btn-ai-generate { border-radius: 12px; font-weight: 700; padding: 0.65rem 1rem; }
    .btn-create-modern {
        border: 0; border-radius: 13px; padding: 0.9rem 1.4rem;
        background: linear-gradient(135deg, var(--brand), var(--brand-dark));
        color: #fff; font-weight: 700; box-shadow: 0 14px 28px rgba(11, 127, 125, 0.34);
    }
    .btn-create-modern:hover { color: #fff; transform: translateY(-1px); }
    .back-link { display: inline-flex; align-items: center; gap: 0.35rem; margin-top: 1rem; color: var(--brand-dark); font-weight: 600; text-decoration: none; }
    .back-link:hover { text-decoration: underline; }
    .evenement-heures-info { margin-top: 0.75rem; border-radius: 12px; }
    @media (max-width: 768px) {
        .create-hero { margin: 1rem 0.75rem 0; border-radius: 18px; padding: 2.3rem 1rem; }
        .create-shell { padding: 1rem 0.75rem 1.5rem; }
    }
</style>

<section class="programme-create-page">
    <div class="create-hero">
        <div class="container">
            <h1>Creer un nouveau programme</h1>
            <p>Mettez en place les horaires et activites de votre evenement.</p>
        </div>
    </div>

    <div class="create-shell">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-10 col-xl-9">
                    <div class="card create-card">
                        <div class="card-body">
                            <div class="info-header">
                                <span class="info-kicker"><i class="bi bi-calendar2-week"></i> Dossier programme</span>
                                <h3 class="create-heading">Informations du programme</h3>
                                <p class="info-subtitle">Remplissez les champs essentiels pour une planification claire.</p>
                            </div>

                            {{ form_start(form, {'attr': {'class': 'new-added-form', 'novalidate': 'novalidate'}}) }}

                            <div class="row g-3 g-md-4">
                                <div class="col-12">
                                    <div class="form-section">
                                        <h4 class="form-section-title"><i class="bi bi-link-45deg"></i> Association evenement</h4>
                                        {{ form_label(form.evenement, null, {'label_attr': {'class': 'field-label'}}) }}
                                        {{ form_widget(form.evenement, {'attr': {'class': 'modern-input form-select form-select-lg' ~ (form.evenement.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                        {% for error in form.evenement.vars.errors %}
                                            <div class="error-text">{{ error.message }}</div>
                                        {% endfor %}
                                        <small class="form-note">Selectionnez l evenement associe a ce programme.</small>
                                    </div>
                                </div>

                                <div class="col-12">
                                    <div class="form-section">
                                        <h4 class="form-section-title"><i class="bi bi-clock-history"></i> Horaires de pause</h4>
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                {{ form_label(form.pauseDebut, null, {'label_attr': {'class': 'field-label'}}) }}
                                                {{ form_widget(form.pauseDebut, {'attr': {'class': 'modern-input form-control form-control-lg' ~ (form.pauseDebut.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                                {% for error in form.pauseDebut.vars.errors %}
                                                    <div class="error-text">{{ error.message }}</div>
                                                {% endfor %}
                                            </div>
                                            <div class="col-md-6">
                                                {{ form_label(form.pauseFin, null, {'label_attr': {'class': 'field-label'}}) }}
                                                {{ form_widget(form.pauseFin, {'attr': {'class': 'modern-input form-control form-control-lg' ~ (form.pauseFin.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                                {% for error in form.pauseFin.vars.errors %}
                                                    <div class="error-text">{{ error.message }}</div>
                                                {% endfor %}
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-12">
                                    <div class="form-section ai-assistant-box">
                                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                                            <h4 class="form-section-title mb-0"><i class="bi bi-list-task"></i> Activites prevues</h4>
                                            <button type="button" id="btn-generate-activities" class="btn btn-outline-primary btn-ai-generate">
                                                <i class="bi bi-stars me-1"></i> Generer avec IA
                                            </button>
                                        </div>
                                        <div id="activity-loading" class="alert alert-info d-none mt-3 mb-0">
                                            <i class="fas fa-spinner fa-spin me-2"></i> Generation des activites en cours...
                                        </div>
                                        <div class="mt-3">
                                            {{ form_widget(form.activites, {'attr': {'rows': 8, 'class': 'modern-input form-control form-control-lg' ~ (form.activites.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                            {% for error in form.activites.vars.errors %}
                                                <div class="error-text">{{ error.message }}</div>
                                            {% endfor %}
                                            <small class="form-note">Detaillez les activites avec horaires si possible.</small>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="form-section h-100">
                                        <h4 class="form-section-title"><i class="bi bi-file-earmark-text"></i> Documents requis</h4>
                                        {{ form_widget(form.documentsRequis, {'attr': {'rows': 7, 'class': 'modern-input form-control form-control-lg' ~ (form.documentsRequis.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                        {% for error in form.documentsRequis.vars.errors %}
                                            <div class="error-text">{{ error.message }}</div>
                                        {% endfor %}
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="form-section h-100">
                                        <h4 class="form-section-title"><i class="bi bi-tools"></i> Materiels requis</h4>
                                        {{ form_widget(form.materielsRequis, {'attr': {'rows': 7, 'class': 'modern-input form-control form-control-lg' ~ (form.materielsRequis.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
                                        {% for error in form.materielsRequis.vars.errors %}
                                            <div class="error-text">{{ error.message }}</div>
                                        {% endfor %}
                                    </div>
                                </div>
                            </div>

                            <div class="mt-4 text-center">
                                <button type="submit" class="btn btn-create-modern w-100">Enregistrer le programme</button>
                            </div>

                            {{ form_end(form) }}
                        </div>
                    </div>

                    <div class="text-center">
                        <a href="{{ path('app_programme_index') }}" class="back-link">
                            <span aria-hidden="true">&larr;</span> Retour a la liste des programmes
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const evenementSelect = document.getElementById('{{ form.evenement.vars.id }}');
    const pauseDebutInput = document.getElementById('{{ form.pauseDebut.vars.id }}');
    const pauseFinInput = document.getElementById('{{ form.pauseFin.vars.id }}');
    const form = document.querySelector('.new-added-form');
    const btnGenerateActivities = document.getElementById('btn-generate-activities');
    const activityLoading = document.getElementById('activity-loading');
    const activitesTextarea = document.getElementById('{{ form.activites.vars.id }}');

    let eventHeureDebut = null;
    let eventHeureFin = null;

    const notify = (message, type = 'info') => {
        if (typeof Swal !== 'undefined') {
            Swal.fire({ icon: type, title: message, position: 'center', confirmButtonText: 'OK' });
        } else {
            alert(message);
        }
    };

    const timeToMinutes = (v) => {
        if (!v) return null;
        const parts = v.split(':');
        return (parseInt(parts[0], 10) * 60) + parseInt(parts[1], 10);
    };

    const showError = (input, message) => {
        if (!input) return;
        input.classList.add('is-invalid');
        let box = input.parentElement.querySelector('.pause-validation-error');
        if (!box) {
            box = document.createElement('div');
            box.className = 'invalid-feedback d-block pause-validation-error';
            input.parentElement.appendChild(box);
        }
        box.innerHTML = '<i class="fas fa-exclamation-triangle me-1"></i> ' + message;
    };

    const clearError = (input) => {
        if (!input) return;
        input.classList.remove('is-invalid');
        const box = input.parentElement.querySelector('.pause-validation-error');
        if (box) box.remove();
    };

    const setEvenementInfo = (message, type = 'info') => {
        if (!evenementSelect) return;
        let infoDiv = document.querySelector('.evenement-heures-info');
        if (!infoDiv) {
            infoDiv = document.createElement('div');
            infoDiv.className = 'alert evenement-heures-info';
            evenementSelect.parentElement.appendChild(infoDiv);
        }
        infoDiv.classList.remove('alert-info', 'alert-warning', 'alert-danger');
        infoDiv.classList.add(type === 'danger' ? 'alert-danger' : (type === 'warning' ? 'alert-warning' : 'alert-info'));
        infoDiv.innerHTML = `<i class="fas fa-info-circle me-1"></i> ${message}`;
    };

    const validatePause = () => {
        if (!pauseDebutInput || !pauseFinInput || !eventHeureDebut || !eventHeureFin) return true;
        const pd = timeToMinutes(pauseDebutInput.value);
        const pf = timeToMinutes(pauseFinInput.value);
        const ed = timeToMinutes(eventHeureDebut);
        const ef = timeToMinutes(eventHeureFin);
        let ok = true;

        clearError(pauseDebutInput);
        clearError(pauseFinInput);

        if (pd === null || pf === null) return true;
        if (pd < ed || pd > ef) { showError(pauseDebutInput, `Heure de debut hors intervalle ${eventHeureDebut} - ${eventHeureFin}.`); ok = false; }
        if (pf < ed || pf > ef) { showError(pauseFinInput, `Heure de fin hors intervalle ${eventHeureDebut} - ${eventHeureFin}.`); ok = false; }
        if (pd >= pf) { showError(pauseDebutInput, 'L heure de debut de pause doit etre avant la fin.'); ok = false; }
        return ok;
    };

    const loadEvenementHeures = (id) => {
        if (!id) {
            eventHeureDebut = null;
            eventHeureFin = null;
            return;
        }
        fetch('{{ path('app_programme_api_evenement_heures', {'id': '__ID__'}) }}'.replace('__ID__', id), {
            headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            credentials: 'same-origin',
        })
        .then((r) => r.json())
        .then((data) => {
            if (!data.success) {
                eventHeureDebut = null;
                eventHeureFin = null;
                setEvenementInfo(data.message || 'Evenement sans horaires valides.', 'warning');
                return;
            }
            eventHeureDebut = data.heureDebut;
            eventHeureFin = data.heureFin;
            setEvenementInfo(`Horaires de l evenement : <strong>${eventHeureDebut}</strong> - <strong>${eventHeureFin}</strong>. La pause doit etre dans cet intervalle.`, 'info');
            validatePause();
        })
        .catch(() => {
            setEvenementInfo('Impossible de charger les horaires de l evenement.', 'danger');
        });
    };

    evenementSelect?.addEventListener('change', () => loadEvenementHeures(evenementSelect.value));
    if (evenementSelect?.value) loadEvenementHeures(evenementSelect.value);
    pauseDebutInput?.addEventListener('input', validatePause);
    pauseFinInput?.addEventListener('input', validatePause);

    form?.addEventListener('submit', function(e) {
        if (!validatePause()) {
            e.preventDefault();
            e.stopPropagation();
            notify('Veuillez corriger les erreurs de pause avant validation.', 'warning');
        }
    });

    btnGenerateActivities?.addEventListener('click', function() {
        const evenementId = evenementSelect?.value || '';
        if (!evenementId) {
            notify('Veuillez d abord selectionner un evenement.', 'warning');
            return;
        }
        if (!eventHeureDebut || !eventHeureFin) {
            notify('Veuillez attendre le chargement des horaires de l evenement.', 'info');
            return;
        }

        btnGenerateActivities.disabled = true;
        activityLoading?.classList.remove('d-none');

        fetch('{{ path('app_programme_api_recommend_activities') }}', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Accept': 'application/json',
                'X-Requested-With': 'XMLHttpRequest',
            },
            credentials: 'same-origin',
            body: JSON.stringify({
                evenement_id: evenementId,
                pause_debut: pauseDebutInput?.value || null,
                pause_fin: pauseFinInput?.value || null
            })
        })
        .then(async (r) => {
            const data = await r.json();
            if (!r.ok || !data.success) throw new Error(data.message || 'Generation impossible.');
            return data;
        })
        .then((data) => {
            if (activitesTextarea) {
                activitesTextarea.value = data.activites || '';
                activitesTextarea.dispatchEvent(new Event('change'));
            }
            notify(data.message || 'Activites generees avec succes.', 'success');
        })
        .catch((err) => notify(err.message || 'Erreur de generation des activites.', 'error'))
        .finally(() => {
            btnGenerateActivities.disabled = false;
            activityLoading?.classList.add('d-none');
        });
    });
});
</script>
{% endblock %}
