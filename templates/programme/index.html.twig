{% extends 'base_backoffice.html.twig' %}

{% block title %}Liste des Programmes{% endblock %}

{% block body %}
    {% set totalProgrammes = programmes|length %}
    {% set programmesAvecDocuments = 0 %}
    {% set programmesAvecMateriels = 0 %}
    {% for programme in programmes %}
        {% if programme.documentsRequis is not empty %}
            {% set programmesAvecDocuments = programmesAvecDocuments + 1 %}
        {% endif %}
        {% if programme.materielsRequis is not empty %}
            {% set programmesAvecMateriels = programmesAvecMateriels + 1 %}
        {% endif %}
    {% endfor %}
    {% set programmesComplets = programmesAvecDocuments < programmesAvecMateriels ? programmesAvecDocuments : programmesAvecMateriels %}

    <style>
        .programme-index-tuned .card {
            border-radius: 14px;
            overflow: hidden;
            animation: panelIn 0.45s ease both;
        }

        .programme-index-tuned .card-header {
            padding-top: 1rem;
            padding-bottom: 1rem;
        }

        .programme-index-tuned .form-control,
        .programme-index-tuned .form-select {
            border-radius: 10px;
        }

        .programme-index-tuned .table thead th {
            font-weight: 700;
            letter-spacing: 0.2px;
        }

        .programme-index-tuned .table tbody tr {
            transition: background-color 0.2s ease;
            animation: rowIn 0.35s ease both;
        }

        .programme-index-tuned .table tbody tr:hover {
            background-color: rgba(13, 110, 253, 0.04);
        }

        .programme-index-tuned .results-meta {
            font-size: 0.85rem;
            color: #6c757d;
            animation: fadeInSoft 0.45s ease both;
        }

        .programme-index-tuned .row.mb-3 {
            animation: slideDownIn 0.45s ease both;
        }

        .programme-index-tuned .row.g-4.mb-4 > div {
            animation: riseIn 0.45s ease both;
        }

        .programme-index-tuned .row.g-4.mb-4 > div:nth-child(2) {
            animation-delay: 0.08s;
        }

        .programme-index-tuned .row.g-4.mb-4 > div:nth-child(3) {
            animation-delay: 0.16s;
        }

        .programme-index-tuned .btn-outline-secondary {
            animation: pulseSoft 1.7s ease-in-out infinite;
        }

        .programme-index-tuned .event-title {
            font-weight: 600;
            color: #1f2937;
        }

        .programme-index-tuned .event-meta {
            font-size: 0.85rem;
            color: #6b7280;
        }

        .programme-index-tuned .content-cell {
            max-width: 300px;
            white-space: pre-wrap;
            color: #374151;
            line-height: 1.5;
            font-size: 0.92rem;
        }

        .programme-index-tuned .table tbody tr:nth-child(1) { animation-delay: 0.02s; }
        .programme-index-tuned .table tbody tr:nth-child(2) { animation-delay: 0.05s; }
        .programme-index-tuned .table tbody tr:nth-child(3) { animation-delay: 0.08s; }
        .programme-index-tuned .table tbody tr:nth-child(4) { animation-delay: 0.11s; }
        .programme-index-tuned .table tbody tr:nth-child(5) { animation-delay: 0.14s; }
        .programme-index-tuned .table tbody tr:nth-child(6) { animation-delay: 0.17s; }

        @keyframes slideDownIn {
            from { opacity: 0; transform: translateY(-8px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes riseIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes panelIn {
            from { opacity: 0; transform: translateY(12px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes fadeInSoft {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        @keyframes rowIn {
            from { opacity: 0; transform: translateX(8px); }
            to { opacity: 1; transform: translateX(0); }
        }

        @keyframes pulseSoft {
            0%, 100% { box-shadow: 0 0 0 0 rgba(108, 117, 125, 0.12); }
            50% { box-shadow: 0 0 0 6px rgba(108, 117, 125, 0.04); }
        }

        @media (max-width: 768px) {
            .programme-index-tuned .card-header .row > div {
                width: 100%;
            }
        }
    </style>

    <div class="programme-index-tuned">
        <div class="row mb-3">
            <div class="col-12 d-sm-flex justify-content-between align-items-center">
                <h1 class="h3 mb-2 mb-sm-0">Programmes</h1>
                <a href="{{ path('app_programme_new') }}" class="btn btn-sm btn-primary mb-0">Creer un programme</a>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-sm-6 col-lg-4">
                <div class="text-center p-4 bg-primary bg-opacity-10 border border-primary rounded-3">
                    <h6>Total Programmes</h6>
                    <h2 class="mb-0 fs-1 text-primary">{{ totalProgrammes }}</h2>
                </div>
            </div>

            <div class="col-sm-6 col-lg-4">
                <div class="text-center p-4 bg-success bg-opacity-10 border border-success rounded-3">
                    <h6>Avec Documents</h6>
                    <h2 class="mb-0 fs-1 text-success">{{ programmesAvecDocuments }}</h2>
                </div>
            </div>

            <div class="col-sm-6 col-lg-4">
                <div class="text-center p-4 bg-warning bg-opacity-15 border border-warning rounded-3">
                    <h6>Complets</h6>
                    <h2 class="mb-0 fs-1 text-warning">{{ programmesComplets }}</h2>
                </div>
            </div>
        </div>

        <div class="card bg-transparent border">
            <div class="card-header bg-light border-bottom">
                <div class="row g-3 align-items-center justify-content-between">
                    <div class="col-md-8">
                        <div class="rounded position-relative">
                            <input id="programmeSearch" class="form-control bg-body" type="search" placeholder="Rechercher par evenement, activites, documents..." aria-label="Search">
                            <span class="btn bg-transparent px-2 py-0 position-absolute top-50 end-0 translate-middle-y me-2">
                                <i class="fas fa-search fs-6 text-primary"></i>
                            </span>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <select id="programmeSort" class="form-select js-choice border-0 z-index-9" aria-label="Sort">
                            <option value="">Tri par defaut</option>
                            <option value="event-az">Evenement A-Z</option>
                            <option value="event-za">Evenement Z-A</option>
                            <option value="date-asc">Date evenement croissante</option>
                            <option value="date-desc">Date evenement decroissante</option>
                            <option value="pause-asc">Pause plus courte</option>
                            <option value="pause-desc">Pause plus longue</option>
                        </select>
                    </div>

                    <div class="col-md-1 text-md-end">
                        <button id="programmeReset" type="button" class="btn btn-sm btn-outline-secondary">Reset</button>
                    </div>
                </div>

                <div id="programmeResultsMeta" class="results-meta mt-2">{{ totalProgrammes }} resultat(s)</div>
            </div>

            <div class="card-body">
                <div class="table-responsive border-0 rounded-3">
                    <table class="table table-dark-gray align-middle p-4 mb-0 table-hover">
                        <thead>
                            <tr>
                                <th scope="col" class="border-0 rounded-start">Evenement</th>
                                <th scope="col" class="border-0">Pause</th>
                                <th scope="col" class="border-0">Activites</th>
                                <th scope="col" class="border-0">Documents</th>
                                <th scope="col" class="border-0">Materiels</th>
                                <th scope="col" class="border-0 rounded-end">Action</th>
                            </tr>
                        </thead>
                        <tbody id="programmeTableBody">
                            {% for programme in programmes %}
                                {% set eventTitle = programme.evenement ? programme.evenement.titre : 'Evenement indisponible' %}
                                {% set eventDateDisplay = programme.evenement and programme.evenement.dateEvenement ? programme.evenement.dateEvenement|date('d/m/Y') : '-' %}
                                {% set eventDateSort = programme.evenement and programme.evenement.dateEvenement ? programme.evenement.dateEvenement|date('Y-m-d') : '' %}
                                {% set activitesText = programme.activites|default('') %}
                                {% set documentsText = programme.documentsRequis|default('') %}
                                {% set materielsText = programme.materielsRequis|default('') %}
                                {% set searchBlob = (eventTitle ~ ' ' ~ activitesText ~ ' ' ~ documentsText ~ ' ' ~ materielsText)|lower %}
                                <tr class="programme-row"
                                    data-search="{{ searchBlob|e('html_attr') }}"
                                    data-event="{{ eventTitle|lower|e('html_attr') }}"
                                    data-date="{{ eventDateSort|e('html_attr') }}"
                                    data-pause="{{ programme.dureePause|default(0) }}">
                                    <td>
                                        <div class="event-title">{{ eventTitle }}</div>
                                        <div class="event-meta">
                                            <i class="fas fa-calendar-day me-1"></i>{{ eventDateDisplay }}
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge text-bg-warning">
                                            {{ programme.pauseDebut ? programme.pauseDebut|date('H:i') : '--:--' }} -
                                            {{ programme.pauseFin ? programme.pauseFin|date('H:i') : '--:--' }}
                                        </span>
                                        <div class="event-meta mt-1">{{ programme.dureePause|default(0) }} min</div>
                                    </td>
                                    <td class="content-cell">{{ activitesText is not empty ? activitesText|nl2br : '-' }}</td>
                                    <td class="content-cell">{{ documentsText is not empty ? documentsText|nl2br : '-' }}</td>
                                    <td class="content-cell">{{ materielsText is not empty ? materielsText|nl2br : '-' }}</td>
                                    <td>
                                        <a href="{{ path('app_programme_show', {'id': programme.id}) }}" class="btn btn-sm btn-success-soft me-1 mb-1 mb-md-0">Detail</a>
                                        <a href="{{ path('app_programme_edit', {'id': programme.id}) }}" class="btn btn-sm btn-warning-soft me-1 mb-1 mb-md-0">Modifier</a>
                                        <form method="post" action="{{ path('app_programme_delete', {'id': programme.id}) }}" style="display:inline;" onsubmit="return confirm('Supprimer ce programme ?')">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ programme.id) }}">
                                            <button type="submit" class="btn btn-sm btn-danger-soft mb-0">Supprimer</button>
                                        </form>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="6">Aucun programme trouve.</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="card-footer bg-transparent pt-0">
                <div class="d-sm-flex justify-content-sm-between align-items-sm-center">
                    <p id="programmeFooterText" class="mb-0 text-center text-sm-start">Affichage de {{ totalProgrammes }} programme(s)</p>
                </div>
            </div>
        </div>
    </div>

    <script>
        (() => {
            const searchInput = document.getElementById('programmeSearch');
            const sortSelect = document.getElementById('programmeSort');
            const resetButton = document.getElementById('programmeReset');
            const tableBody = document.getElementById('programmeTableBody');
            const resultsMeta = document.getElementById('programmeResultsMeta');
            const footerText = document.getElementById('programmeFooterText');

            if (!tableBody) {
                return;
            }

            const rows = Array.from(tableBody.querySelectorAll('.programme-row'));
            const totalRows = rows.length;

            const updateMeta = (visibleCount) => {
                if (resultsMeta) {
                    resultsMeta.textContent = visibleCount + ' resultat(s)';
                }
                if (footerText) {
                    footerText.textContent = 'Affichage de ' + visibleCount + ' programme(s)';
                }
            };

            const sortRows = (value) => {
                const getDateKey = (row) => row.dataset.date || '';
                const getPauseKey = (row) => Number.parseInt(row.dataset.pause || '0', 10);
                const getEventKey = (row) => row.dataset.event || '';

                rows.sort((a, b) => {
                    if (value === 'event-az') {
                        return getEventKey(a).localeCompare(getEventKey(b));
                    }
                    if (value === 'event-za') {
                        return getEventKey(b).localeCompare(getEventKey(a));
                    }
                    if (value === 'date-asc') {
                        return getDateKey(a).localeCompare(getDateKey(b));
                    }
                    if (value === 'date-desc') {
                        return getDateKey(b).localeCompare(getDateKey(a));
                    }
                    if (value === 'pause-asc') {
                        return getPauseKey(a) - getPauseKey(b);
                    }
                    if (value === 'pause-desc') {
                        return getPauseKey(b) - getPauseKey(a);
                    }
                    return 0;
                });

                rows.forEach((row) => tableBody.appendChild(row));
            };

            const applyFilter = () => {
                const query = (searchInput?.value || '').trim().toLowerCase();
                const selectedSort = sortSelect?.value || '';

                sortRows(selectedSort);

                let visibleCount = 0;
                rows.forEach((row) => {
                    const haystack = row.dataset.search || '';
                    const visible = query === '' || haystack.includes(query);
                    row.style.display = visible ? '' : 'none';
                    if (visible) {
                        visibleCount++;
                    }
                });

                updateMeta(visibleCount);
            };

            searchInput?.addEventListener('input', applyFilter);
            sortSelect?.addEventListener('change', applyFilter);
            resetButton?.addEventListener('click', () => {
                if (searchInput) {
                    searchInput.value = '';
                }
                if (sortSelect) {
                    sortSelect.value = '';
                }
                rows.forEach((row) => {
                    row.style.display = '';
                    tableBody.appendChild(row);
                });
                updateMeta(totalRows);
            });
        })();
    </script>
{% endblock %}
