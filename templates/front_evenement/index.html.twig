{% extends 'base_frontoffice.html.twig' %}

{% block title %}Evenements - EduKids{% endblock %}

{% block body %}
<section class="bg-blue align-items-center d-flex" style="background:url('{{ asset('assets/images/pattern/04.png') }}') no-repeat center center; background-size:cover;">
    <div class="container">
        <div class="row">
            <div class="col-12 text-center">
                <h1 class="text-white">Nos Evenements</h1>
                <div class="d-flex justify-content-center">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb breadcrumb-dark breadcrumb-dots mb-0">
                            <li class="breadcrumb-item"><a href="{{ path('home') }}">Home</a></li>
                            <li class="breadcrumb-item active" aria-current="page">Evenements</li>
                        </ol>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row mb-4 align-items-center g-3">
            <div class="col-xl-8">
                <form id="eventSearchForm" class="border rounded p-3" onsubmit="return false;">
                    <div class="row g-2 align-items-center">
                        <div class="col-md-7">
                            <div class="input-group input-borderless">
                                <input id="event-search-input" class="form-control me-1" type="search" placeholder="Rechercher un evenement..." autocomplete="off">
                                <button type="button" class="btn btn-primary mb-0 rounded z-index-1" id="event-search-btn">
                                    <i class="fas fa-search"></i>
                                </button>
                            </div>
                        </div>
                        <div class="col-md-5">
                            <select id="event-sort-select" class="form-select">
                                <option value="date_desc">Plus recent</option>
                                <option value="date_asc">Plus ancien</option>
                                <option value="likes_desc">Plus populaire</option>
                                <option value="title_asc">Titre A-Z</option>
                                <option value="title_desc">Titre Z-A</option>
                            </select>
                        </div>
                    </div>
                </form>
            </div>
            <div class="col-xl-4 d-flex justify-content-xl-end align-items-center">
                <p id="event-count" class="mb-0 text-end">{{ evenements|length }} evenement(s)</p>
            </div>
        </div>

        <div id="events-grid" class="row g-4">
            {% for evenement in evenements %}
                {% set isFavorite = (userFavorites|default({}))[evenement.id]|default(false) %}
                {% set userReaction = (userReactions|default({}))[evenement.id]|default(null) %}
                <div
                    class="col-sm-6 col-xl-4 event-item"
                    data-title="{{ evenement.titre|lower }}"
                    data-description="{{ evenement.description|striptags|lower }}"
                    data-date="{{ evenement.dateEvenement ? evenement.dateEvenement|date('Y-m-d') : '9999-12-31' }}"
                    data-likes="{{ evenement.likesCount }}"
                >
                    <div class="card shadow h-100">
                        {% if evenement.image %}
                            <img src="{{ asset('uploads/' ~ evenement.image) }}" class="card-img-top" alt="{{ evenement.titre }}" style="height:220px; object-fit:cover;">
                        {% else %}
                            <img src="{{ asset('assets/images/event/01.jpg') }}" class="card-img-top" alt="{{ evenement.titre }}" style="height:220px; object-fit:cover;">
                        {% endif %}

                        <div class="card-body pb-0">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="badge bg-primary bg-opacity-10 text-primary">
                                    {{ evenement.dateEvenement ? evenement.dateEvenement|date('d/m/Y') : 'Date a definir' }}
                                </span>
                                <span class="badge bg-success bg-opacity-10 text-success">
                                    {{ evenement.heureDebut ? evenement.heureDebut|date('H:i') : '--:--' }} - {{ evenement.heureFin ? evenement.heureFin|date('H:i') : '--:--' }}
                                </span>
                            </div>

                            <div class="d-flex align-items-start justify-content-between gap-2">
                                <h5 class="card-title mb-2">
                                    <a href="{{ path('app_front_evenement_show', {'id': evenement.id}) }}">{{ evenement.titre }}</a>
                                </h5>
                                <button
                                    type="button"
                                    class="favorite-btn-card favorite-btn-{{ evenement.id }} {{ isFavorite ? 'active-favorite' : '' }}"
                                    onclick="toggleFavorite({{ evenement.id }}, event)"
                                    title="Favori"
                                >
                                    <i class="{{ isFavorite ? 'fas' : 'far' }} fa-heart"></i>
                                </button>
                            </div>

                            <p class="mb-2 text-truncate-2">
                                {{ evenement.description|striptags|slice(0, 105) }}{% if evenement.description|length > 105 %}...{% endif %}
                            </p>

                            <div class="mb-2">
                                {% if evenement.programme %}
                                    <span class="badge bg-success bg-opacity-10 text-success">Programme disponible</span>
                                {% else %}
                                    <span class="badge bg-warning bg-opacity-10 text-warning">Programme a venir</span>
                                {% endif %}
                            </div>
                        </div>

                        <div class="card-footer pt-0 pb-3">
                            <hr>
                            <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap">
                                <div class="d-flex align-items-center gap-2">
                                    <button type="button" class="reaction-btn-mini like-btn-{{ evenement.id }} {{ userReaction == 'like' ? 'active-like' : '' }}" onclick="reactToEvent({{ evenement.id }}, 'like', event)" title="Like">
                                        <span class="reaction-circle-mini like-circle-mini"><i class="fas fa-thumbs-up"></i></span>
                                        <span class="reaction-count-mini likes-count-{{ evenement.id }}">{{ evenement.likesCount }}</span>
                                    </button>
                                    <button type="button" class="reaction-btn-mini dislike-btn-{{ evenement.id }} {{ userReaction == 'dislike' ? 'active-dislike' : '' }}" onclick="reactToEvent({{ evenement.id }}, 'dislike', event)" title="Dislike">
                                        <span class="reaction-circle-mini dislike-circle-mini"><i class="fas fa-thumbs-down"></i></span>
                                        <span class="reaction-count-mini dislikes-count-{{ evenement.id }}">{{ evenement.dislikesCount }}</span>
                                    </button>
                                </div>
                                <div class="d-flex gap-2">
                                    <button
                                        type="button"
                                        class="btn btn-sm btn-success"
                                        {% if app.user %}
                                            onclick="loadReservationModal({{ evenement.id }})"
                                            {% if evenement.nbPlacesDisponibles is not null and not evenement.hasPlacesDisponibles() %}disabled title="Plus de places disponibles"{% endif %}
                                        {% else %}
                                            onclick="window.location.href='{{ path('app_login') }}'"
                                            title="Connectez-vous pour participer"
                                        {% endif %}
                                    >
                                        Participer
                                    </button>
                                    <a href="{{ path('app_front_evenement_show', {'id': evenement.id}) }}" class="btn btn-sm btn-primary">Details</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12 text-center py-5">
                    <p class="mb-0">Aucun evenement trouve.</p>
                </div>
            {% endfor %}
        </div>

        <div id="events-no-results" class="text-center py-5 d-none">
            <p class="mb-0">Aucun resultat pour cette recherche.</p>
        </div>
    </div>
</section>

<style>
.event-item { transition: opacity .2s ease; }
.favorite-btn-card {
    background: none;
    border: none;
    color: #6b7280;
    font-size: 1.15rem;
    line-height: 1;
    padding: 0.15rem 0.25rem;
}
.favorite-btn-card:hover,
.favorite-btn-card.active-favorite { color: #e91e63; }
.reaction-btn-mini {
    background: none;
    border: none;
    padding: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
}
.reaction-circle-mini {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    border: 1px solid;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
}
.like-circle-mini { border-color: #28a745; color: #28a745; }
.dislike-circle-mini { border-color: #dc3545; color: #dc3545; }
.reaction-btn-mini.active-like .like-circle-mini { background: #28a745; color: #fff; }
.reaction-btn-mini.active-dislike .dislike-circle-mini { background: #dc3545; color: #fff; }
.reaction-count-mini { font-size: 0.8rem; font-weight: 600; color: #4b5563; }
</style>

<script>
(function () {
    var searchInput = document.getElementById('event-search-input');
    var searchBtn = document.getElementById('event-search-btn');
    var sortSelect = document.getElementById('event-sort-select');
    var countNode = document.getElementById('event-count');
    var noResults = document.getElementById('events-no-results');
    var grid = document.getElementById('events-grid');

    if (!grid) return;

    var items = Array.prototype.slice.call(grid.querySelectorAll('.event-item'));
    var total = items.length;

    function applyFilters() {
        var query = (searchInput ? searchInput.value : '').trim().toLowerCase();
        var mode = sortSelect ? sortSelect.value : 'date_desc';

        items.sort(function (a, b) {
            var aDate = a.dataset.date || '';
            var bDate = b.dataset.date || '';
            var aTitle = a.dataset.title || '';
            var bTitle = b.dataset.title || '';
            var aLikes = parseInt(a.dataset.likes || '0', 10);
            var bLikes = parseInt(b.dataset.likes || '0', 10);

            if (mode === 'date_asc') return aDate.localeCompare(bDate);
            if (mode === 'likes_desc') return bLikes - aLikes;
            if (mode === 'title_asc') return aTitle.localeCompare(bTitle);
            if (mode === 'title_desc') return bTitle.localeCompare(aTitle);
            return bDate.localeCompare(aDate);
        });

        items.forEach(function (item) { grid.appendChild(item); });

        var visible = 0;
        items.forEach(function (item) {
            var haystack = ((item.dataset.title || '') + ' ' + (item.dataset.description || '')).toLowerCase();
            var show = query === '' || haystack.indexOf(query) !== -1;
            item.style.display = show ? '' : 'none';
            if (show) visible += 1;
        });

        if (countNode) {
            countNode.textContent = visible + ' evenement(s)';
        }

        if (noResults) {
            noResults.classList.toggle('d-none', visible !== 0 || total === 0);
        }
    }

    if (searchInput) searchInput.addEventListener('input', applyFilters);
    if (searchBtn) searchBtn.addEventListener('click', applyFilters);
    if (sortSelect) sortSelect.addEventListener('change', applyFilters);
    applyFilters();
})();

function reactToEvent(eventId, type, e) {
    e.preventDefault();
    e.stopPropagation();

    fetch('/interaction/' + type + '/' + eventId, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(function (response) { return response.json(); })
    .then(function (data) {
        if (!data.success) return;

        var likesCount = document.querySelector('.likes-count-' + eventId);
        var dislikesCount = document.querySelector('.dislikes-count-' + eventId);
        var likeBtn = document.querySelector('.like-btn-' + eventId);
        var dislikeBtn = document.querySelector('.dislike-btn-' + eventId);

        if (likesCount) likesCount.textContent = data.likes;
        if (dislikesCount) dislikesCount.textContent = data.dislikes;
        if (likeBtn) likeBtn.classList.remove('active-like');
        if (dislikeBtn) dislikeBtn.classList.remove('active-dislike');
        if (data.userReaction === 'like' && likeBtn) likeBtn.classList.add('active-like');
        if (data.userReaction === 'dislike' && dislikeBtn) dislikeBtn.classList.add('active-dislike');
    });
}

function toggleFavorite(eventId, e) {
    e.preventDefault();
    e.stopPropagation();

    fetch('/interaction/favorite/' + eventId, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(function (response) { return response.json(); })
    .then(function (data) {
        if (!data.success) return;

        var favoriteBtn = document.querySelector('.favorite-btn-' + eventId);
        if (!favoriteBtn) return;

        var heartIcon = favoriteBtn.querySelector('i');
        if (data.isFavorite) {
            favoriteBtn.classList.add('active-favorite');
            if (heartIcon) {
                heartIcon.classList.remove('far');
                heartIcon.classList.add('fas');
            }
        } else {
            favoriteBtn.classList.remove('active-favorite');
            if (heartIcon) {
                heartIcon.classList.remove('fas');
                heartIcon.classList.add('far');
            }
        }

        updateFavoritesBadge(data.totalUserFavorites);
    });
}

function updateFavoritesBadge(count) {
    var navFavIcon = document.querySelector('.nav-favorites-icon');
    if (!navFavIcon) return;

    var badge = navFavIcon.querySelector('.favorites-badge');
    if (count > 0) {
        var displayCount = count > 99 ? '99+' : count;
        if (badge) {
            badge.textContent = displayCount;
        } else {
            badge = document.createElement('span');
            badge.className = 'favorites-badge';
            badge.textContent = displayCount;
            navFavIcon.appendChild(badge);
        }
    } else if (badge) {
        badge.remove();
    }
}

function loadReservationModal(evenementId) {
    var modalElement = document.getElementById('reservationModal' + evenementId);
    if (modalElement) {
        var modal = new bootstrap.Modal(modalElement);
        modal.show();
        return;
    }

    fetch('/reservation/participer/' + evenementId, {
        method: 'GET',
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(function (response) { return response.text(); })
    .then(function (html) {
        var tempDiv = document.createElement('div');
        tempDiv.innerHTML = html;
        var modalHtml = tempDiv.querySelector('.modal');
        if (!modalHtml) return;

        document.body.appendChild(modalHtml);
        var modal = new bootstrap.Modal(modalHtml);
        modal.show();
        modalHtml.addEventListener('hidden.bs.modal', function () {
            modalHtml.remove();
        });
    })
    .catch(function () {
        alert('Erreur lors du chargement du formulaire.');
    });
}
</script>
{% endblock %}
