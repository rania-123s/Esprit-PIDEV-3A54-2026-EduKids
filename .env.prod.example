APP_ENV=prod
APP_DEBUG=0
APP_SECRET=change_this_to_a_long_random_secret

# Replace these values with the MySQL credentials from the hosting panel.
DATABASE_URL="mysql://db_user:db_password@127.0.0.1:3306/db_name?serverVersion=10.11.2-MariaDB&charset=utf8mb4"

# Replace with the real public URL after deployment.
DEFAULT_URI="https://example.com"

# Mail and optional APIs. Keep real values only on the hosting platform, not in Git.
MAILER_DSN=null://null
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI providers used by the project. Fill only the providers you use.
POLLINATIONS_API_KEY=
GEMINI_API_KEY=
GOOGLE_GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1
GROQ_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
ATTACHMENT_SUMMARY_API_KEY=

# Local/self-hosted services. Leave empty on shared hosting unless you expose a public service URL.
OLLAMA_BASE_URL=
OLLAMA_TEXT_MODEL=
LIBRETRANSLATE_URL=

# Optional real-time chat values.
CHAT_WS_PUBLIC_URL=
CHAT_WS_BRIDGE_URL=
CHAT_WS_BIND_HOST=0.0.0.0
CHAT_WS_BIND_PORT=8081
CHAT_WS_BRIDGE_SECRET=
